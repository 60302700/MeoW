<style>
    .sim-wrap {
        width: 100%;
        max-width: 460px;
        padding: 1rem;
    }

    .sim-card {
        background: white;
        border-radius: 1.5rem;
        box-shadow: 0 8px 40px rgba(0,0,0,0.10);
        overflow: hidden;
    }

    .sim-header {
        background: linear-gradient(135deg, #9d174d, #ec4899);
        padding: 1.5rem 1.75rem 1.25rem;
    }

    .sim-header h1 {
        margin: 0;
        color: white;
        font-size: 1.35rem;
        font-weight: 800;
    }

    .sim-body {
        padding: 1.5rem 1.75rem;
    }

    .sim-body p.intro {
        font-size: 0.88rem;
        color: #475569;
        line-height: 1.65;
        margin: 0 0 1.35rem;
    }

    .field-label {
        display: block;
        font-size: 0.75rem;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 0.35rem;
    }

    .sim-input {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        font-size: 0.9rem;
        color: #0f172a;
        outline: none;
        box-sizing: border-box;
        transition: border-color 0.2s;
        background: #f8fafc;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        letter-spacing: 0.03em;
    }

    .sim-input:focus { border-color: #ec4899; background: white; }

    .sim-btn {
        width: 100%;
        padding: 0.85rem;
        background: linear-gradient(135deg, #9d174d, #ec4899);
        color: white;
        border: none;
        border-radius: 0.75rem;
        font-size: 0.95rem;
        font-weight: 700;
        cursor: pointer;
        transition: opacity 0.15s;
        margin-top: 0.9rem;
    }

    .sim-btn:hover { opacity: 0.92; }
</style>

<div class="sim-wrap">
<div class="sim-card">
    <div class="sim-header">
        <h1>QR Code Simulator</h1>
    </div>
    <div class="sim-body">
        <p class="intro">Simulate someone finding a cat and scanning its MeoW tag. Paste the cat's QR code below to open its finder page.</p>

        <form method="GET" action="/scan">
            <label class="field-label">Cat's QR Code ID</label>
            <input type="text" name="qr" class="sim-input" placeholder="e.g. a1b2c3d4-..." required maxlength="64" autofocus>
            <button type="submit" class="sim-btn">Simulate scan</button>
        </form>
    </div>
</div>
</div>