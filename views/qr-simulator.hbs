<style>
    .sim-wrap {
        width: 100%;
        max-width: 940px;
        padding: 1rem;
    }

    .sim-head {
        text-align: center;
        margin-bottom: 2rem;
    }

    .sim-badge {
        display: inline-block;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #be185d;
        background: #fdf2f8;
        border: 1px solid #fbcfe8;
        padding: 0.3rem 0.85rem;
        border-radius: 999px;
        margin-bottom: 0.9rem;
    }

    .sim-head h1 {
        font-size: 1.8rem;
        font-weight: 800;
        color: #0f172a;
        margin: 0 0 0.5rem;
    }

    .sim-head p {
        font-size: 0.9rem;
        color: #64748b;
        line-height: 1.6;
        max-width: 560px;
        margin: 0 auto;
    }

    .sim-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 1.25rem;
    }

    .sim-card {
        background: white;
        border: 1px solid #f1f5f9;
        border-radius: 1.25rem;
        padding: 1.5rem;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
        text-align: center;
        transition: border-color 0.2s, transform 0.2s;
    }

    .sim-card:hover {
        border-color: #fbcfe8;
        transform: translateY(-3px);
    }

    .sim-cat-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.7rem;
        margin-bottom: 1.1rem;
    }

    .sim-cat-photo {
        width: 40px;
        height: 40px;
        border-radius: 0.6rem;
        object-fit: cover;
        border: 1px solid #fbcfe8;
    }

    .sim-cat-name {
        font-size: 1.05rem;
        font-weight: 800;
        color: #0f172a;
    }

    .sim-qr {
        width: 180px;
        height: 180px;
        border: 2px solid #1e293b;
        border-radius: 0.5rem;
        display: block;
        margin: 0 auto 1rem;
    }

    .sim-id {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.7rem;
        color: #94a3b8;
        word-break: break-all;
        margin-bottom: 1rem;
    }

    .sim-open-btn {
        display: inline-block;
        width: 100%;
        box-sizing: border-box;
        padding: 0.75rem;
        background: linear-gradient(135deg, #ec4899, #a855f7);
        color: white;
        border-radius: 0.75rem;
        font-size: 0.9rem;
        font-weight: 700;
        text-decoration: none;
        transition: opacity 0.15s;
    }

    .sim-open-btn:hover { opacity: 0.92; }

    .sim-empty {
        text-align: center;
        background: white;
        border: 1px solid #f1f5f9;
        border-radius: 1.25rem;
        padding: 3rem 2rem;
        color: #64748b;
    }

    .sim-empty a { color: #ec4899; font-weight: 700; text-decoration: none; }

    @media (max-width: 480px) {
        .sim-head h1 { font-size: 1.4rem; }
    }
</style>

<div class="sim-wrap">
    <div class="sim-head">
        <span class="sim-badge">Demo Tool</span>
        <h1>QR Code Simulator</h1>
        <p>These are the QR codes printed on each cat's MeoW tag. On a phone that can reach this server, scan a code. On a laptop, just click "Open finder page" to simulate someone scanning the tag after finding the cat.</p>
    </div>

    {{#if cats.length}}
    <div class="sim-grid">
        {{#each cats}}
        <div class="sim-card">
            <div class="sim-cat-row">
                {{#if this.photoUrl}}
                <img src="{{this.photoUrl}}" class="sim-cat-photo" alt="{{this.name}}">
                {{/if}}
                <span class="sim-cat-name">{{this.name}}</span>
            </div>
            <img src="{{this.qrImage}}" class="sim-qr" alt="QR code for {{this.name}}">
            <div class="sim-id">{{this.qrCodeId}}</div>
            <a href="{{this.scanUrl}}" class="sim-open-btn">Open finder page</a>
        </div>
        {{/each}}
    </div>
    {{else}}
    <div class="sim-empty">
        <p>No cats have been registered yet. <a href="/register">Create an account</a> and add a cat to generate its QR code.</p>
    </div>
    {{/if}}
</div>