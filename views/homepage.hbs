                            </div>

                            <div style="display:flex;flex-direction:column;gap:0.3rem;margin-top:0.5rem;">
                                {{#if this.priorityOrder}}
                                <span style="font-size:0.72rem;color:#94a3b8;font-weight:600;text-transform:uppercase;letter-spacing:0.04em;">Priority #{{this.priorityOrder}}</span>
                                {{/if}}
                                {{#if this.phone}}
                                <span style="display:flex;align-items:center;gap:0.4rem;font-size:0.78rem;color:#64748b;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                    {{this.phone}}
                                </span>
                                {{/if}}
                                {{#if this.email}}
                                <span style="display:flex;align-items:center;gap:0.4rem;font-size:0.78rem;color:#64748b;min-width:0;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                                    <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{this.email}}</span>
                                </span>
                                {{/if}}
                            </div>
                        </div>
                    </div>
                    {{/each}}
                </div>

                <!-- ── Per-guardian edit modals ────────────────────────── -->
                {{#each guardians}}
                <div id="editGuardianModal-{{this.Id}}"
                    style="display:none;position:fixed;inset:0;background:rgba(15,23,42,0.6);backdrop-filter:blur(6px);z-index:8000;align-items:center;justify-content:center;"
                    onclick="if(event.target===this)closeEditGuardian('{{this.Id}}')">
                    <div style="background:white;border-radius:1.5rem;padding:2rem;width:90%;max-width:420px;box-shadow:0 25px 60px rgba(0,0,0,0.15);position:relative;">
                        <button onclick="closeEditGuardian('{{this.Id}}')"
                            style="position:absolute;top:1rem;right:1rem;background:none;border:none;font-size:1.3rem;cursor:pointer;color:#94a3b8;line-height:1;">&#10005;</button>
                        <h2 style="font-size:1.2rem;font-weight:800;color:#0f172a;margin:0 0 1.5rem;">Edit Guardian</h2>
                        <form method="POST" action="/guardians/edit/{{this._id}}">
                            <input type="hidden" name="_csrf" value="{{../csrfToken}}">
                            <div style="display:flex;align-items:center;gap:1rem;margin-bottom:0.85rem;">
                                {{#if this.photoUrl}}
                                <img src="{{this.photoUrl}}" alt="{{this.name}}"
                                    style="width:52px;height:52px;border-radius:50%;object-fit:cover;border:1px solid #e2e8f0;flex-shrink:0;">
                                {{else}}
                                <div style="width:52px;height:52px;border-radius:50%;background:linear-gradient(135deg,#ec4899,#a855f7);color:white;display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-weight:800;flex-shrink:0;">{{initial this.name}}</div>
                                {{/if}}
                                <label style="flex-grow:1;display:block;padding:0.6rem 0.85rem;border:2px dashed #e2e8f0;border-radius:0.65rem;font-size:0.82rem;color:#94a3b8;cursor:pointer;text-align:center;transition:border-color 0.2s;"
                                    onmouseover="this.style.borderColor='#ec4899'" onmouseout="this.style.borderColor='#e2e8f0'">
                                    Replace photo
                                    <input type="file" name="photo" accept="image/*" style="display:none;" onchange="this.parentElement.textContent=this.files[0]?this.files[0].name:'Replace photo'">
                                </label>
                            </div>
                            <div style="margin-bottom:0.85rem;">
                                <label style="display:block;font-size:0.75rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.04em;margin-bottom:0.3rem;">Name</label>
                                <input type="text" name="name" value="{{this.name}}" required
                                    style="width:100%;padding:0.7rem 0.9rem;border:2px solid #e2e8f0;border-radius:0.65rem;font-size:0.9rem;color:#0f172a;outline:none;box-sizing:border-box;transition:border-color 0.2s;"
                                    onfocus="this.style.borderColor='#ec4899'" onblur="this.style.borderColor='#e2e8f0'">
                            </div>
                            <div style="margin-bottom:0.85rem;">
                                <label style="display:block;font-size:0.75rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.04em;margin-bottom:0.3rem;">Email</label>
                                <input type="email" name="email" value="{{this.email}}"
                                    style="width:100%;padding:0.7rem 0.9rem;border:2px solid #e2e8f0;border-radius:0.65rem;font-size:0.9rem;color:#0f172a;outline:none;box-sizing:border-box;transition:border-color 0.2s;"
                                    onfocus="this.style.borderColor='#ec4899'" onblur="this.style.borderColor='#e2e8f0'">
                            </div>
                            <div style="margin-bottom:0.85rem;">
                                <label style="display:block;font-size:0.75rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.04em;margin-bottom:0.3rem;">Phone</label>
                                <input type="tel" name="phone" value="{{this.phone}}"
                                    style="width:100%;padding:0.7rem 0.9rem;border:2px solid #e2e8f0;border-radius:0.65rem;font-size:0.9rem;color:#0f172a;outline:none;box-sizing:border-box;transition:border-color 0.2s;"
                                    onfocus="this.style.borderColor='#ec4899'" onblur="this.style.borderColor='#e2e8f0'">
                            </div>
                            <div style="margin-bottom:1.5rem;">
                                <label style="display:block;font-size:0.75rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.04em;margin-bottom:0.3rem;">Priority Order</label>
                                <input type="number" name="priorityOrder" value="{{this.priorityOrder}}" min="1"
                                    style="width:100%;padding:0.7rem 0.9rem;border:2px solid #e2e8f0;border-radius:0.65rem;font-size:0.9rem;color:#0f172a;outline:none;box-sizing:border-box;transition:border-color 0.2s;"
                                    onfocus="this.style.borderColor='#ec4899'" onblur="this.style.borderColor='#e2e8f0'">
                            </div>
                            <div style="display:flex;gap:0.75rem;">
                                <button type="button" onclick="closeEditGuardian('{{this.Id}}')"
                                    style="flex:1;padding:0.85rem;background:none;border:2px solid #e2e8f0;border-radius:0.75rem;font-size:0.9rem;font-weight:600;color:#64748b;cursor:pointer;">Cancel</button>
                                <button type="submit"
                                    style="flex:2;padding:0.85rem;background:linear-gradient(135deg,#ec4899,#a855f7);color:white;border:none;border-radius:0.75rem;font-size:0.95rem;font-weight:700;cursor:pointer;box-shadow:0 4px 18px rgba(236,72,153,0.3);">Save Changes</button>
                            </div>
                        </form>
                        <form method="POST" action="/guardians/{{this._id}}/delete" style="margin-top:0.75rem;"
                            onsubmit="return confirm('Remove {{this.name}} as a guardian? This cannot be undone.')">
                            <input type="hidden" name="_csrf" value="{{../csrfToken}}">
                            <button type="submit"
                                style="width:100%;padding:0.75rem;background:none;border:2px solid #fecdd3;border-radius:0.75rem;font-size:0.9rem;font-weight:600;color:#e11d48;cursor:pointer;transition:all 0.15s;"
                                onmouseover="this.style.background='#fff1f2'" onmouseout="this.style.background='none'">Remove Guardian</button>
                        </form>
                    </div>
                </div>
                {{/each}}

                {{else}}
                <div class="gh-empty">
                    <div class="empty-icon">🤝</div>
                    <h4>No guardians assigned</h4>
                    <p>Add trusted people who can respond if your cat triggers an emergency.</p>
                </div>
                {{/if}}

            </div>
        </div>
        <div id="Cats" style="display:none">
            <div class="container">

                <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.75rem;margin-bottom:0.5rem;">
                    <h1 style="margin:0;">Cats</h1>
                    <button type="button" onclick="openAddCat()"
                        style="background:linear-gradient(135deg,#ec4899,#a855f7);color:white;border:none;border-radius:0.75rem;padding:0.65rem 1.2rem;font-size:0.9rem;font-weight:700;cursor:pointer;box-shadow:0 4px 18px rgba(236,72,153,0.3);white-space:nowrap;">
                        + Add Cat
                    </button>
                </div>

                {{#if hasCats}}
                <div class="gh-section-title">
                    <h3>Your Registered Cats</h3>
                </div>
                <div class="gh-repo-grid">
                    {{#each cats}}
                    <div class="gh-repo-card" style="display:flex;flex-direction:row;gap:0.9rem;align-items:center;padding:0.85rem 1rem;">
                        {{#if this.photoUrl}}
                        <img src="{{this.photoUrl}}" style="width:44px;height:44px;border-radius:8px;object-fit:cover;border:1px solid #e2e8f0;flex-shrink:0;" alt="{{this.name}}">
                        {{else}}
                        <div style="width:44px;height:44px;border-radius:8px;background:linear-gradient(135deg,#fce7f3,#f5f3ff);display:flex;align-items:center;justify-content:center;flex-shrink:0;border:1px solid #e2e8f0;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#ec4899" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="3.5" r="1.5"/><circle cx="15" cy="3.5" r="1.5"/><circle cx="4.5" cy="8.5" r="1.5"/><circle cx="19.5" cy="8.5" r="1.5"/><path d="M9 12c-2.5 0-5 2-5 6 0 2.5 2 3 4 3 1.5 0 3-0.5 4-0.5s2.5 0.5 4 0.5c2 0 4-0.5 4-3 0-4-2.5-6-5-6-1.5 0-2.5 0.5-3 0.5S10.5 12 9 12z"/></svg>
                        </div>
                        {{/if}}
                        <div style="flex-grow:1;min-width:0;">
                            <div style="display:flex;align-items:center;justify-content:space-between;gap:0.5rem;">
                                <a href="/cats/{{this.name}}" style="font-size:0.92rem;font-weight:700;color:#ec4899;text-decoration:none;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{this.name}}</a>
                                {{#if this.isActiveBackupProtocol}}
                                <span class="repo-visibility" style="flex-shrink:0;">Protected</span>
                                {{/if}}
                            </div>
                            <div style="display:flex;align-items:center;gap:0.6rem;margin-top:0.3rem;flex-wrap:wrap;">
                                {{#if this.breed}}<span style="font-size:0.75rem;color:#64748b;">{{this.breed}}</span>{{/if}}
                                {{#if this.gender}}<span style="font-size:0.75rem;color:#94a3b8;">·</span><span style="font-size:0.75rem;color:#64748b;">{{this.gender}}</span>{{/if}}
                                {{#if this.age}}<span style="font-size:0.75rem;color:#94a3b8;">·</span><span style="font-size:0.75rem;color:#64748b;">{{this.age}} yrs</span>{{/if}}
                            </div>
                        </div>
                    </div>
                    {{/each}}
                </div>
                {{else}}
                <div class="gh-empty">
                    <div class="empty-icon"></div>
                    <h4>No cats registered yet</h4>
                    <p>Click "Add Cat" to register your first cat.</p>
                </div>
                {{/if}}

                <!-- ── Add Cat modal ──────────────────────────────────────── -->
                <div id="addCatModal" style="display:none;position:fixed;inset:0;background:rgba(15,23,42,0.6);backdrop-filter:blur(6px);z-index:8000;align-items:center;justify-content:center;">
                <div style="background:white;border-radius:1.5rem;padding:2rem;width:90%;max-width:520px;box-shadow:0 25px 60px rgba(0,0,0,0.15);position:relative;max-height:90vh;overflow-y:auto;">
                    <button type="button" onclick="closeAddCat()"
                        style="position:absolute;top:1rem;right:1rem;background:none;border:none;font-size:1.3rem;cursor:pointer;color:#94a3b8;line-height:1;">&#10005;</button>

                    <h2 style="font-size:1.2rem;font-weight:800;color:#0f172a;margin:0 0 1.5rem;">Add a New Cat</h2>

                <form id="catForm" method="POST" action="/cats" enctype="multipart/form-data">
                    <input type="hidden" name="_csrf" value="{{csrfToken}}">

                    <p style="font-size:0.75rem;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.06em;margin:0 0 0.75rem;">Basic Info</p>

                    <div class="form-group">
                        <label>Cat Name</label>
                        <input type="text" id="name" name="name" required>
                    </div>
                    <div class="form-group">
                        <label>Breed</label>
                        <input type="text" id="breed" name="breed">
                    </div>
                    <div class="form-group">
                        <label>Age (years)</label>
                        <input type="number" id="age" name="age" min="0">
                    </div>
                    <div class="form-group">
                        <label>Gender</label>
                        <select name="gender">
                            <option value="">Not specified</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Photo</label>
                        <input type="file" id="photoInput" name="photo" accept="image/*">
                    </div>
                    <div class="form-group">
                        <label>Microchip Number</label>
                        <input type="text" name="microchip" placeholder="15-digit ISO chip number">
                    </div>
                    <div class="form-group">
                        <label>Passport / Travel Document Number</label>
                        <input type="text" name="passportNumber" placeholder="e.g. EU passport number">
                    </div>
                    <div class="form-group">
                        <label>Neutered / Spayed</label>
                        <select name="neutered">
                            <option value="">Not specified</option>
                            <option value="yes">Yes</option>
                            <option value="no">No</option>
                        </select>
                    </div>

                    <hr style="border:none;border-top:1px solid #f1f5f9;margin:1.25rem 0 1rem;">
                    <p style="font-size:0.75rem;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.06em;margin:0 0 0.75rem;">Diet & Feeding</p>

                    <div class="form-group">
                        <label>Feeding Schedule</label>
                        <input type="text" name="feedingSchedule" placeholder="e.g. Twice daily, 80g dry food at 8am and 6pm">
                    </div>
                    <div class="form-group">
                        <label>Food Brand / Type</label>
                        <input type="text" name="foodBrand" placeholder="e.g. Royal Canin Adult Indoor">
                    </div>
                    <div class="form-group">
                        <label>Food Allergies / Intolerances</label>
                        <input type="text" name="allergies" placeholder="e.g. Chicken, fish-based foods">
                    </div>

                    <hr style="border:none;border-top:1px solid #f1f5f9;margin:1.25rem 0 1rem;">
                    <p style="font-size:0.75rem;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.06em;margin:0 0 0.75rem;">Medical</p>

                    <div class="form-group">
                        <label>Known Conditions</label>
                        <textarea name="conditions" rows="2" placeholder="e.g. Asthma, chronic kidney disease"></textarea>
                    </div>
                    <div class="form-group">
                        <label>Current Medications</label>
                        <textarea name="medications" rows="2" placeholder="e.g. Prednisolone 5mg once daily with food"></textarea>
                    </div>
                    <div class="form-group">
                        <label>Vaccinations</label>
                        <textarea name="vaccinations" rows="2" placeholder="e.g. Rabies: Jan 2025 (next Jan 2026), FVRCP: Mar 2025"></textarea>
                    </div>

                    <hr style="border:none;border-top:1px solid #f1f5f9;margin:1.25rem 0 1rem;">
                    <p style="font-size:0.75rem;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.06em;margin:0 0 0.75rem;">Veterinarian</p>

                    <div class="form-group">
                        <label>Vet Name / Clinic</label>
                        <input type="text" name="vetName" placeholder="e.g. Dr. Smith — City Vet Clinic">
                    </div>
                    <div class="form-group">
                        <label>Vet Phone</label>
                        <input type="tel" name="vetPhone" placeholder="+1 555 000 0000">
                    </div>

                    <hr style="border:none;border-top:1px solid #f1f5f9;margin:1.25rem 0 1rem;">
                    <p style="font-size:0.75rem;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.06em;margin:0 0 0.75rem;">Personality & Notes</p>

                    <div class="form-group">
                        <label>Personality / Habits</label>
                        <textarea name="personality" rows="2" placeholder="e.g. Shy with strangers, loves being brushed, indoor only"></textarea>
                    </div>
                    <div class="form-group">
                        <label>Caretaker Notes</label>
                        <textarea name="notes" rows="2" placeholder="Anything important a temporary guardian should know"></textarea>
                    </div>

                    <button type="submit">
                        Add Cat
                    </button>

                </form>
                </div>
                </div>
                <!-- ──────────────────────────────────────────────────────── -->
            </div>
        </div>

        <div id="Guardians" style="display:none">
            <div class="container">
                <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.75rem;margin-bottom:0.5rem;">
                    <h1 style="margin:0;">Guardian Search</h1>
                    <button type="button" onclick="openAddGuardian()"
                        style="background:linear-gradient(135deg,#ec4899,#a855f7);color:white;border:none;border-radius:0.75rem;padding:0.65rem 1.2rem;font-size:0.9rem;font-weight:700;cursor:pointer;box-shadow:0 4px 18px rgba(236,72,153,0.3);white-space:nowrap;">
                        + Add Guardian
                    </button>
                </div>

                <div class="form-group">
                    <label for="guardianSearch">Search by name</label>
                    <input type="text" id="guardianSearch" placeholder="Start typing a user name..." style="width:100%;padding:0.75rem 1rem;border:2px solid #e2e8f0;border-radius:0.75rem;font-size:0.95rem;color:#0f172a;outline:none;box-sizing:border-box;">
                </div>

                <div id="guardianSearchInfo" style="margin-bottom: 1rem; color: #475569; font-size: 0.85rem;">Search for a MeoW user by name to add them as a trusted emergency guardian for your cats.</div>

                <div id="guardianSearchResults" style="margin-bottom: 1.5rem;">
                    {{#if hasGuardians}}
                    <div id="guardianCards" class="gh-repo-grid">
                        {{#each guardians}}
                        <div class="gh-repo-card guardian-card" data-guardian-name="{{this.name}}" style="display:flex;flex-direction:row;gap:0.85rem;align-items:flex-start;">
                            {{#if this.photoUrl}}
                            <img src="{{this.photoUrl}}" alt="{{this.name}}"
                                style="width:36px;height:36px;border-radius:50%;object-fit:cover;border:1px solid #e2e8f0;flex-shrink:0;">
                            {{else}}
                            <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#ec4899,#a855f7);color:white;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:800;flex-shrink:0;">{{initial this.name}}</div>
                            {{/if}}
                            <div style="flex-grow:1;min-width:0;display:flex;flex-direction:column;gap:0.5rem;">
                            <div class="repo-top-row">
                                <span class="repo-name">{{this.name}}</span>
                                {{#if this.hasAccepted}}
                                <span class="repo-visibility">Accepted</span>
                                {{/if}}
                            </div>
                            <div style="display:flex;flex-direction:column;gap:0.3rem;margin-top:0.2rem;">
                                {{#if this.phone}}
                                <span style="display:flex;align-items:center;gap:0.4rem;font-size:0.78rem;color:#64748b;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                    {{this.phone}}
                                </span>
                                {{/if}}
                                {{#if this.email}}
                                <span style="display:flex;align-items:center;gap:0.4rem;font-size:0.78rem;color:#64748b;min-width:0;">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                                    <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{this.email}}</span>
                                </span>
                                {{/if}}
                            </div>
                            {{#if this.priorityOrder}}
                            <span class="repo-meta-item" style="font-size:0.72rem;color:#64748b;">Priority #{{this.priorityOrder}}</span>
                            {{/if}}
                            </div>
                        </div>
                        {{/each}}
                    </div>
                    {{else}}
                    <div class="gh-empty">
                        <div class="empty-icon">🤝</div>
                        <h4>No guardians assigned yet</h4>
                        <p>Click "Add Guardian" above to add your first guardian.</p>
                    </div>
                    {{/if}}
                    <div id="guardianSearchEmpty" style="display:none;margin-top:1rem;color:#7c3aed;font-size:0.95rem;">No matching users found.</div>
                </div>

                <!-- ── Add Guardian modal ─────────────────────────────────── -->
                <div id="addGuardianModal" style="display:none;position:fixed;inset:0;background:rgba(15,23,42,0.6);backdrop-filter:blur(6px);z-index:8000;align-items:center;justify-content:center;">
                <div style="background:white;border-radius:1.5rem;padding:2rem;width:90%;max-width:460px;box-shadow:0 25px 60px rgba(0,0,0,0.15);position:relative;max-height:90vh;overflow-y:auto;">
                    <button type="button" onclick="closeAddGuardian()"
                        style="position:absolute;top:1rem;right:1rem;background:none;border:none;font-size:1.3rem;cursor:pointer;color:#94a3b8;line-height:1;">&#10005;</button>

                    <h2 style="font-size:1.2rem;font-weight:800;color:#0f172a;margin:0 0 0.35rem;">Add a Guardian</h2>
                    <p style="margin: 0 0 1.25rem; color: #475569; font-size: 0.88rem;">
                        Use this form to add a guardian directly to your account.
                    </p>

                <form method="POST" action="/guardians" enctype="multipart/form-data">
                    <input type="hidden" name="_csrf" value="{{csrfToken}}">
                    <div class="form-group">
                        <label for="g-name">Full Name</label>
                        <input type="text" id="g-name" name="name" placeholder="e.g. John Doe" required>
                    </div>

                    <div class="form-group">
                        <label for="g-photo">Photo</label>
                        <input type="file" id="g-photo" name="photo" accept="image/*">
                    </div>

                    <div class="form-group">
                        <label for="g-email">Email Address</label>
                        <input type="email" id="g-email" name="email" placeholder="e.g. john@example.com" required>
                    </div>

                    <div class="form-group">
                        <label for="g-phone">Phone Number</label>
                        <input type="tel" id="g-phone" name="phone" placeholder="e.g. +974 5555 1234" required>
                    </div>

                    <div class="form-group">
                        <label for="g-priority">Priority Order</label>
                        <select id="g-priority" name="priorityOrder" required>
                            <option value="1">Priority #1 (Immediate responder)</option>
                            <option value="2">Priority #2 (Backup responder)</option>
                            <option value="3">Priority #3</option>
                            <option value="4">Priority #4</option>
                        </select>
                    </div>

                    <button type="submit">
                        Register Guardian
                    </button>
                </form>
                </div>
                </div>
                <!-- ──────────────────────────────────────────────────────── -->
            </div>
        </div>



        <script nonce="{{nonce}}">
            // Generate the GitHub-style activity grid with random paw-print activity
            (function () {
                const grid = document.getElementById('activityGrid');
                if (!grid) return;

                const weeks = 52;
                for (let w = 0; w < weeks; w++) {
                    const col = document.createElement('div');
                    col.className = 'contrib-col';
                    for (let d = 0; d < 3; d++) {
                        const cell = document.createElement('div');
                        cell.className = 'contrib-cell';
                        const r = Math.random();
                        if (r > 0.82) cell.classList.add('l4');
                        else if (r > 0.7) cell.classList.add('l3');
                        else if (r > 0.55) cell.classList.add('l2');
                        else if (r > 0.35) cell.classList.add('l1');
                        col.appendChild(cell);
                    }
                    grid.appendChild(col);
                }
            })();

            function showOverview() {
                document.getElementById('Overview').style.display = 'block';
                document.getElementById('Cats').style.display = 'none';
                document.getElementById('Guardians').style.display = 'none';
            }

            function showCats() {
                document.getElementById('Overview').style.display = 'none';
                document.getElementById('Cats').style.display = 'block';
                document.getElementById('Guardians').style.display = 'none';
            }

            function showGuardians() {
                document.getElementById('Overview').style.display = 'none';
                document.getElementById('Guardians').style.display = 'block';
                document.getElementById('Cats').style.display = 'none';
            }

            function initGuardianSearch() {
                const input = document.getElementById('guardianSearch');
                const cards = Array.from(document.querySelectorAll('.guardian-card'));
                const emptyMessage = document.getElementById('guardianSearchEmpty');
                if (!input || cards.length === 0) return;

                input.addEventListener('input', () => {
                    const query = input.value.trim().toLowerCase();
                    let matchCount = 0;

                    cards.forEach(card => {
                        const name = card.dataset.guardianName.toLowerCase();
                        const visible = query === '' || name.includes(query);
                        card.style.display = visible ? 'flex' : 'none';
                        if (visible) matchCount += 1;
                    });

                    const status = document.getElementById('guardianSearchInfo');
                    if (status) {
                        if (query === '') {
                            status.textContent = 'Search for a MeoW user by name to add them as a trusted emergency guardian for your cats.';
                        } else if (matchCount === 0) {
                            status.textContent = 'No registered MeoW users match that name.';
                        } else {
                            status.textContent = `${matchCount} guardian${matchCount === 1 ? '' : 's'} found.`;
                        }
                    }

                    if (emptyMessage) {
                        emptyMessage.style.display = query !== '' && matchCount === 0 ? 'block' : 'none';
                    }
                });
            }

            function openEditProfile() {
                document.getElementById('editProfileModal').style.display = 'flex';
                document.body.style.overflow = 'hidden';
            }
            function openChangePassword() {
                document.getElementById('changePasswordModal').style.display = 'flex';
                document.body.style.overflow = 'hidden';
            }
            function closeChangePassword() {
                document.getElementById('changePasswordModal').style.display = 'none';
                document.body.style.overflow = '';
            }
            function closeEditProfile() {
                document.getElementById('editProfileModal').style.display = 'none';
                document.body.style.overflow = '';
                hideDeleteConfirm();
            }
            function showDeleteConfirm() {
                document.getElementById('deleteAccountTrigger').style.display = 'none';
                document.getElementById('deleteAccountConfirm').style.display = 'block';
            }
            function hideDeleteConfirm() {
                document.getElementById('deleteAccountTrigger').style.display = 'block';
                document.getElementById('deleteAccountConfirm').style.display = 'none';
            }
            const _modal = document.getElementById('editProfileModal');
            if (_modal) _modal.addEventListener('click', function (e) {
                if (e.target === this) closeEditProfile();
            });
            const _pwModal = document.getElementById('changePasswordModal');
            if (_pwModal) _pwModal.addEventListener('click', function (e) {
                if (e.target === this) closeChangePassword();
            });

            function checkPwStrength(inputId, rulesId) {
                const val = document.getElementById(inputId).value;
                const box = document.getElementById(rulesId);
                box.style.display = val.length > 0 ? 'block' : 'none';
                const rules = {
                    len:  val.length >= 8,
                    up:   /[A-Z]/.test(val),
                    low:  /[a-z]/.test(val),
                    num:  /[0-9]/.test(val),
                    spec: /[^A-Za-z0-9]/.test(val),
                };
                box.querySelectorAll('[data-rule]').forEach(el => {
                    const ok = rules[el.dataset.rule];
                    el.style.color = ok ? '#16a34a' : '#ef4444';
                    el.innerHTML = (ok ? '&#10003;' : '&#10007;') + ' ' + el.textContent.slice(2);
                });
            }

            function openEditGuardian(id) {
                const m = document.getElementById('editGuardianModal-' + id);
                if (m) { m.style.display = 'flex'; document.body.style.overflow = 'hidden'; }
            }
            function closeEditGuardian(id) {
                const m = document.getElementById('editGuardianModal-' + id);
                if (m) { m.style.display = 'none'; document.body.style.overflow = ''; }
            }

            function openAddCat() {
                const m = document.getElementById('addCatModal');
                if (m) { m.style.display = 'flex'; document.body.style.overflow = 'hidden'; }
            }
            function closeAddCat() {
                const m = document.getElementById('addCatModal');
                if (m) { m.style.display = 'none'; document.body.style.overflow = ''; }
            }

            function openAddGuardian() {
                const m = document.getElementById('addGuardianModal');
                if (m) { m.style.display = 'flex'; document.body.style.overflow = 'hidden'; }
            }
            function closeAddGuardian() {
                const m = document.getElementById('addGuardianModal');
                if (m) { m.style.display = 'none'; document.body.style.overflow = ''; }
            }

            // Profile photo upload
            document.getElementById('profilePhotoInput').addEventListener('change', async function () {
                const file = this.files[0];
                if (!file) return;

                // Instant preview
                const reader = new FileReader();
                reader.onload = e => {
                    document.getElementById('profileAvatar').src = e.target.result;
                };
                reader.readAsDataURL(file);

                // Upload
                const formData = new FormData();
                formData.append('photo', file);
                formData.append('_csrf', document.querySelector('meta[name="csrf-token"]').content);
                try {
                    const res = await fetch('/profile/photo', { method: 'POST', body: formData });
                    if (!res.ok) throw new Error('Upload failed');
                    showToast('Profile photo updated.', 'success');
                } catch (err) {
                    showToast('Could not save photo. Please try again.', 'error');
                }
                this.value = '';
            });

            function showToast(msg, type) {
                const isError = type === 'error';
                const icon = isError
                    ? `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`
                    : `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`;
                const color = isError ? '#991b1b' : '#166534';
                const bg = isError ? '#fef2f2' : '#f0fdf4';
                const border = isError ? '#fca5a5' : '#86efac';
                const toast = document.createElement('div');
                toast.style.cssText = `position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);background:${bg};border:1px solid ${border};border-radius:0.85rem;padding:0.8rem 1.25rem;box-shadow:0 8px 30px rgba(0,0,0,0.1);font-size:0.875rem;font-weight:600;color:${color};z-index:9999;display:flex;align-items:center;gap:0.6rem;white-space:nowrap;max-width:90vw;`;
                toast.innerHTML = icon + `<span>${msg}</span>`;
                document.body.appendChild(toast);
                setTimeout(() => toast.remove(), 3500);
            }

            // Show success toast on redirect
            (function () {
                const params = new URLSearchParams(window.location.search);
                if (params.get('success') === 'profile') {
                    showToast('Profile updated successfully.', 'success');
                    window.history.replaceState({}, '', '/homepage');
                } else if (params.get('success') === 'password') {
                    showToast('Password changed successfully.', 'success');
                    window.history.replaceState({}, '', '/homepage');
                } else if (params.get('success') === 'cat') {
                    showToast('Cat profile saved.', 'success');
                    window.history.replaceState({}, '', '/homepage');
                } else if (params.get('success') === 'guardian') {
                    showToast('Guardian updated.', 'success');
                    window.history.replaceState({}, '', '/homepage');
                }
            })();

            initGuardianSearch();
        </script>

        <!-- ── Edit Profile Modal ─────────────────────────────────────────── -->
        <div id="editProfileModal"
            style="display:none;position:fixed;inset:0;background:rgba(15,23,42,0.6);backdrop-filter:blur(6px);z-index:8000;align-items:center;justify-content:center;">
            <div
                style="background:white;border-radius:1.5rem;padding:2rem;width:90%;max-width:440px;box-shadow:0 25px 60px rgba(0,0,0,0.15);position:relative;max-height:90vh;overflow-y:auto;">
                <button onclick="closeEditProfile()"
                    style="position:absolute;top:1rem;right:1rem;background:none;border:none;font-size:1.3rem;cursor:pointer;color:#94a3b8;line-height:1;">&#10005;</button>

                <h2 style="font-size:1.25rem;font-weight:800;color:#0f172a;margin:0 0 1.5rem;">Edit Profile</h2>

                <form method="POST" action="/profile/edit">
                    <input type="hidden" name="_csrf" value="{{csrfToken}}">
                    <div style="margin-bottom:1rem;">
                        <label style="display:block;font-size:0.78rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.04em;margin-bottom:0.35rem;">Full Name</label>
                        <input type="text" name="name" value="{{user.name}}" required
                            style="width:100%;padding:0.75rem 1rem;border:2px solid #e2e8f0;border-radius:0.75rem;font-size:0.95rem;color:#0f172a;outline:none;box-sizing:border-box;transition:border-color 0.2s;"
                            onfocus="this.style.borderColor='#ec4899'" onblur="this.style.borderColor='#e2e8f0'">
                    </div>
                    <div style="margin-bottom:1.5rem;">
                        <label style="display:block;font-size:0.78rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.04em;margin-bottom:0.35rem;">Phone</label>
                        <input type="tel" name="phone" value="{{user.phone}}"
                            style="width:100%;padding:0.75rem 1rem;border:2px solid #e2e8f0;border-radius:0.75rem;font-size:0.95rem;color:#0f172a;outline:none;box-sizing:border-box;transition:border-color 0.2s;"
                            onfocus="this.style.borderColor='#ec4899'" onblur="this.style.borderColor='#e2e8f0'">
                    </div>
                    <div style="display:flex;gap:0.75rem;">
                        <button type="button" onclick="closeEditProfile()"
                            style="flex:1;padding:0.85rem;background:none;border:2px solid #e2e8f0;border-radius:0.75rem;font-size:0.9rem;font-weight:600;color:#64748b;cursor:pointer;">
                            Cancel
                        </button>
                        <button type="submit"
                            style="flex:2;padding:0.85rem;background:linear-gradient(135deg,#ec4899,#a855f7);color:white;border:none;border-radius:0.75rem;font-size:0.95rem;font-weight:700;cursor:pointer;box-shadow:0 4px 18px rgba(236,72,153,0.3);">
                            Save Changes
                        </button>
                    </div>
                </form>

                <!-- Delete Account -->
                <div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid #f1f5f9;">
                    <p style="font-size:0.78rem;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.06em;margin:0 0 0.35rem;">Delete Account</p>
                    <p style="font-size:0.82rem;color:#94a3b8;margin:0 0 1rem;line-height:1.5;">Permanently removes your account, cats, guardians, and all associated data.</p>

                    <div id="deleteAccountTrigger">
                        <button type="button" onclick="showDeleteConfirm()"
                            style="padding:0.65rem 1.25rem;background:none;border:1.5px solid #e2e8f0;border-radius:0.65rem;font-size:0.85rem;font-weight:600;color:#64748b;cursor:pointer;transition:all 0.2s;"
                            onmouseover="this.style.borderColor='#fca5a5';this.style.color='#b91c1c'" onmouseout="this.style.borderColor='#e2e8f0';this.style.color='#64748b'">
                            Delete my account
                        </button>
                    </div>

                    <div id="deleteAccountConfirm" style="display:none;">
                        <p style="font-size:0.82rem;color:#64748b;margin:0 0 0.75rem;">Enter your password to confirm. This cannot be undone.</p>
                        <form method="POST" action="/account/delete">
                            <input type="hidden" name="_csrf" value="{{csrfToken}}">
                            <input type="password" name="password" placeholder="Current password" required
                                style="width:100%;padding:0.75rem 1rem;border:2px solid #e2e8f0;border-radius:0.75rem;font-size:0.9rem;color:#0f172a;outline:none;box-sizing:border-box;margin-bottom:0.75rem;transition:border-color 0.2s;"
                                onfocus="this.style.borderColor='#ef4444'" onblur="this.style.borderColor='#e2e8f0'">
                            <div style="display:flex;gap:0.6rem;">
                                <button type="button" onclick="hideDeleteConfirm()"
                                    style="flex:1;padding:0.75rem;background:none;border:2px solid #e2e8f0;border-radius:0.75rem;font-size:0.85rem;font-weight:600;color:#64748b;cursor:pointer;">
                                    Cancel
                                </button>
                                <button type="submit"
                                    style="flex:2;padding:0.75rem;background:#dc2626;color:white;border:none;border-radius:0.75rem;font-size:0.85rem;font-weight:700;cursor:pointer;">
                                    Delete permanently
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Change Password Modal ─────────────────────────────────────── -->
        <div id="changePasswordModal"
            style="display:none;position:fixed;inset:0;background:rgba(15,23,42,0.6);backdrop-filter:blur(6px);z-index:8000;align-items:center;justify-content:center;">
            <div
                style="background:white;border-radius:1.5rem;padding:2rem;width:90%;max-width:420px;box-shadow:0 25px 60px rgba(0,0,0,0.15);position:relative;">
                <button onclick="closeChangePassword()"
                    style="position:absolute;top:1rem;right:1rem;background:none;border:none;font-size:1.3rem;cursor:pointer;color:#94a3b8;line-height:1;">&#10005;</button>

                <h2 style="font-size:1.25rem;font-weight:800;color:#0f172a;margin:0 0 1.5rem;">Change Password</h2>

                <form method="POST" action="/profile/password">
                    <input type="hidden" name="_csrf" value="{{csrfToken}}">
                    <div style="margin-bottom:1rem;">
                        <label style="display:block;font-size:0.78rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.04em;margin-bottom:0.35rem;">Current Password</label>
                        <input type="password" name="currentPassword" required
                            style="width:100%;padding:0.75rem 1rem;border:2px solid #e2e8f0;border-radius:0.75rem;font-size:0.95rem;color:#0f172a;outline:none;box-sizing:border-box;transition:border-color 0.2s;"
                            onfocus="this.style.borderColor='#ec4899'" onblur="this.style.borderColor='#e2e8f0'">
                    </div>
                    <div style="margin-bottom:1rem;">
                        <label style="display:block;font-size:0.78rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.04em;margin-bottom:0.35rem;">New Password</label>
                        <input type="password" id="newPasswordChg" name="newPassword" minlength="8" required
                            style="width:100%;padding:0.75rem 1rem;border:2px solid #e2e8f0;border-radius:0.75rem;font-size:0.95rem;color:#0f172a;outline:none;box-sizing:border-box;transition:border-color 0.2s;"
                            onfocus="this.style.borderColor='#ec4899'" onblur="this.style.borderColor='#e2e8f0'"
                            oninput="checkPwStrength('newPasswordChg','pw-rules-chg')">
                        <div id="pw-rules-chg" style="display:none;margin-top:0.5rem;padding:0.65rem 0.85rem;background:#f8fafc;border:1px solid #e2e8f0;border-radius:0.65rem;">
                            <p data-rule="len"  style="font-size:0.76rem;margin:0 0 0.2rem;color:#94a3b8;">&#10007; At least 8 characters</p>
                            <p data-rule="up"   style="font-size:0.76rem;margin:0 0 0.2rem;color:#94a3b8;">&#10007; One uppercase letter</p>
                            <p data-rule="low"  style="font-size:0.76rem;margin:0 0 0.2rem;color:#94a3b8;">&#10007; One lowercase letter</p>
                            <p data-rule="num"  style="font-size:0.76rem;margin:0 0 0.2rem;color:#94a3b8;">&#10007; One number</p>
                            <p data-rule="spec" style="font-size:0.76rem;margin:0;color:#94a3b8;">&#10007; One special character</p>
                        </div>
                    </div>
                    <div style="margin-bottom:1.5rem;">
                        <label style="display:block;font-size:0.78rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.04em;margin-bottom:0.35rem;">Confirm New Password</label>
                        <input type="password" name="confirmNewPassword" minlength="6" required
                            style="width:100%;padding:0.75rem 1rem;border:2px solid #e2e8f0;border-radius:0.75rem;font-size:0.95rem;color:#0f172a;outline:none;box-sizing:border-box;transition:border-color 0.2s;"
                            onfocus="this.style.borderColor='#ec4899'" onblur="this.style.borderColor='#e2e8f0'">
                    </div>
                    <div style="display:flex;gap:0.75rem;">
                        <button type="button" onclick="closeChangePassword()"
                            style="flex:1;padding:0.85rem;background:none;border:2px solid #e2e8f0;border-radius:0.75rem;font-size:0.9rem;font-weight:600;color:#64748b;cursor:pointer;">
                            Cancel
                        </button>
                        <button type="submit"
                            style="flex:2;padding:0.85rem;background:linear-gradient(135deg,#ec4899,#a855f7);color:white;border:none;border-radius:0.75rem;font-size:0.95rem;font-weight:700;cursor:pointer;box-shadow:0 4px 18px rgba(236,72,153,0.3);">
                            Update Password
                        </button>
                    </div>
                </form>
            </div>
        </div>