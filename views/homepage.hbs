<style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

    /* ==========================================
       GITHUB-STYLE PROFILE LAYOUT
       ========================================== */
    .gh-profile {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        margin: 50px;
        display: grid;
        grid-template-columns: 296px 1fr;
        gap: 2rem;
        align-items: start;
        height: 900px;
    }

    @media (max-width: 820px) {
        .gh-profile {
            grid-template-columns: 1fr;
            padding: 1rem;
        }
    }

    /* ── LEFT SIDEBAR ── */
    .gh-sidebar {
        position: sticky;
        top: 80px;
    }

    .gh-avatar-wrap {
        position: relative;
        margin-bottom: 1rem;
        cursor: pointer;
    }

    .gh-avatar {
        width: 100%;
        aspect-ratio: 1 / 1;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid rgba(236, 72, 153, 0.15);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
        transition: box-shadow 0.3s ease, filter 0.25s ease;
        display: block;
    }

    .gh-avatar-wrap:hover .gh-avatar {
        box-shadow: 0 8px 30px rgba(236, 72, 153, 0.35);
        filter: brightness(0.72);
    }

    .gh-avatar-cam {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.22s ease;
        pointer-events: none;
    }

    .gh-avatar-wrap:hover .gh-avatar-cam {
        opacity: 1;
    }

    .gh-avatar-cam-icon {
        background: rgba(255,255,255,0.92);
        border-radius: 50%;
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.45rem;
        box-shadow: 0 2px 12px rgba(0,0,0,0.18);
    }

    .gh-emoji-status {
        position: absolute;
        bottom: 8%;
        right: 8%;
        width: 40px;
        height: 40px;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        cursor: default;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        pointer-events: none;
    }

    .gh-display-name {
        font-size: 1.5rem;
        font-weight: 800;
        color: #0f172a;
        margin: 0;
        line-height: 1.3;
    }

    .gh-username {
        font-size: 1.15rem;
        font-weight: 400;
        color: #64748b;
        margin: 0 0 0.75rem;
    }

    .gh-bio {
        font-size: 0.875rem;
        color: #334155;
        margin-bottom: 1rem;
        line-height: 1.5;
    }


    .gh-unavail-btn {
        width: 100%;
        padding: 0.45rem 1rem;
        border-radius: 0.5rem;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s, border-color 0.2s;
        margin-bottom: 1rem;
        border: 1px solid #fca5a5;
        background: #fff5f5;
        color: #b91c1c;
    }

    .gh-unavail-btn:hover {
        background: #fee2e2;
        border-color: #f87171;
    }

    .gh-unavail-btn.is-unavailable {
        border-color: #86efac;
        background: #f0fdf4;
        color: #166534;
    }

    .gh-unavail-btn.is-unavailable:hover {
        background: #dcfce7;
        border-color: #4ade80;
    }

    /* Stats row */
    .gh-stats {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.8rem;
        color: #64748b;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }

    .gh-stats a {
        color: inherit;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.3rem;
        transition: color 0.2s;
    }

    .gh-stats a:hover {
        color: #ec4899;
    }

    .gh-stats .stat-count {
        font-weight: 700;
        color: #0f172a;
    }

    .gh-stats .stat-dot {
        color: #cbd5e1;
    }

    /* Sidebar detail items */
    .gh-detail-list {
        list-style: none;
        padding: 0;
        margin: 0 0 1rem;
    }

    .gh-detail-list li {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        font-size: 0.8rem;
        color: #334155;
        padding: 0.25rem 0;
    }

    .gh-detail-list li .detail-icon {
        color: #94a3b8;
        font-size: 0.9rem;
        width: 1.2rem;
        text-align: center;
        flex-shrink: 0;
    }

    /* Achievements / badges */
    .gh-badges {
        border-top: 1px solid #e2e8f0;
        padding-top: 1rem;
        margin-top: 0.5rem;
    }

    .gh-badges h4 {
        font-size: 0.75rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0 0 0.65rem;
    }

    .badge-row {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .gh-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.25rem 0.65rem;
        border-radius: 999px;
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        border: 1px solid;
    }

    .badge-guardian {
        background: #fdf2f8;
        border-color: #fbcfe8;
        color: #be185d;
    }

    .badge-protocol {
        background: #f0fdf4;
        border-color: #bbf7d0;
        color: #166534;
    }

    /* ── RIGHT CONTENT AREA ── */
    .gh-content {}

    /* Tab-style section header */
    .gh-section-bar {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        border-bottom: 1px solid #e2e8f0;
        margin-bottom: 1rem;
        padding-bottom: 0;
    }

    .gh-tab {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.6rem 0.25rem;
        font-size: 0.835rem;
        font-weight: 600;
        color: #64748b;
        text-decoration: none;
        border-bottom: 2px solid transparent;
        margin-bottom: -1px;
        transition: color 0.2s, border-color 0.2s;
        cursor: default;
    }

    .gh-tab .tab-icon {
        font-size: 0.95rem;
    }

    .gh-tab .tab-count {
        background: #f1f5f9;
        color: #334155;
        padding: 0.05rem 0.5rem;
        border-radius: 999px;
        font-size: 0.7rem;
        font-weight: 700;
    }

    .gh-tab:hover {
        color: #0f172a;
        cursor: pointer;
    }

    /* Section title row */
    .gh-section-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.75rem;
        margin-top: 0.5rem;
    }

    .gh-section-title h3 {
        font-size: 0.95rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
    }

    .gh-section-title a {
        font-size: 0.75rem;
        color: #ec4899;
        text-decoration: none;
        font-weight: 500;
        transition: text-decoration 0.2s;
    }

    .gh-section-title a:hover {
        text-decoration: underline;
    }

    /* ── REPO-STYLE CAT CARDS (2-col grid) ── */
    .gh-repo-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    @media (max-width: 720px) {
        .gh-repo-grid {
            grid-template-columns: 1fr;
        }
    }

    .gh-repo-card {
        padding: 1rem 1.25rem;
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        background: #ffffff;
        transition: border-color 0.2s;
        display: flex;
        flex-direction: column;
        min-height: 130px;
    }

    .gh-repo-card:hover {
        border-color: #ec4899;
    }

    /* Repo card top row — name + visibility badge */
    .repo-top-row {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        margin-bottom: 0.4rem;
        flex-wrap: wrap;
    }

    .repo-name {
        font-size: 0.9rem;
        font-weight: 700;
        color: #ec4899;
        text-decoration: none;
        transition: text-decoration 0.15s;
        cursor: default;
    }

    .repo-name:hover {
        text-decoration: underline;
    }

    .repo-visibility {
        padding: 0.05rem 0.45rem;
        border: 1px solid #e2e8f0;
        border-radius: 999px;
        font-size: 0.65rem;
        font-weight: 500;
        color: #64748b;
        flex-shrink: 0;
    }

    /* Repo description */
    .repo-desc {
        font-size: 0.78rem;
        color: #64748b;
        line-height: 1.5;
        margin-bottom: auto;
        padding-bottom: 0.75rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Repo footer row — language dot + breed + age */
    .repo-footer {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.72rem;
        color: #64748b;
        margin-top: auto;
        flex-wrap: wrap;
    }

    .repo-lang {
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    .lang-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    /* Breed-based color dots (cat-themed) */
    .lang-dot.persian {
        background: #f97316;
    }

    .lang-dot.siamese {
        background: #3b82f6;
    }

    .lang-dot.mainecoon {
        background: #8b5cf6;
    }

    .lang-dot.bengal {
        background: #22c55e;
    }

    .lang-dot.ragdoll {
        background: #ec4899;
    }

    .lang-dot.british {
        background: #eab308;
    }

    .lang-dot.abyssinian {
        background: #ef4444;
    }

    .lang-dot.sphynx {
        background: #06b6d4;
    }

    .lang-dot.default-breed {
        background: #ec4899;
    }

    .repo-meta-item {
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    /* ── CONTRIBUTION GRAPH SECTION ── */
    .gh-contrib-section {
        margin-top: 1.5rem;
        margin-bottom: 2rem;
    }

    .gh-contrib-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.75rem;
    }

    .gh-contrib-header h3 {
        font-size: 0.95rem;
        font-weight: 400;
        color: #0f172a;
        margin: 0;
    }

    .gh-contrib-header h3 strong {
        font-weight: 700;
    }

    /* The activity grid container */
    .contrib-graph {
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        padding: 1rem 1.25rem;
        background: #ffffff;
        overflow-x: auto;
    }

    .contrib-grid {
        display: flex;
        gap: 3px;
        align-items: flex-end;
    }

    .contrib-col {
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    .contrib-cell {
        width: 11px;
        height: 11px;
        border-radius: 2px;
        background: #f1f5f9;
        transition: background 0.15s;
    }

    .contrib-cell.l1 {
        background: rgba(236, 72, 153, 0.2);
    }

    .contrib-cell.l2 {
        background: rgba(236, 72, 153, 0.45);
    }

    .contrib-cell.l3 {
        background: rgba(236, 72, 153, 0.7);
    }

    .contrib-cell.l4 {
        background: #ec4899;
    }

    .contrib-months {
        display: flex;
        gap: 3px;
        margin-bottom: 6px;
        padding-left: 30px;
    }

    .contrib-month-label {
        font-size: 0.65rem;
        color: #64748b;
        flex: 1;
        min-width: 40px;
    }

    .contrib-days {
        display: flex;
        flex-direction: column;
        gap: 3px;
        margin-right: 6px;
        padding-top: 0;
    }

    .contrib-day-label {
        font-size: 0.62rem;
        color: #64748b;
        height: 11px;
        display: flex;
        align-items: center;
        line-height: 1;
    }

    .contrib-body {
        display: flex;
    }

    .contrib-legend {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 4px;
        margin-top: 0.65rem;
        font-size: 0.65rem;
        color: #64748b;
    }

    .contrib-legend .contrib-cell {
        width: 11px;
        height: 11px;
    }

    /* ── EMPTY STATE ── */
    .gh-empty {
        text-align: center;
        padding: 2.5rem 1.5rem;
        border: 1px dashed #e2e8f0;
        border-radius: 0.5rem;
        margin-bottom: 2rem;
    }

    .gh-empty .empty-icon {
        font-size: 2.5rem;
        margin-bottom: 0.6rem;
    }

    .gh-empty h4 {
        font-size: 0.95rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0 0 0.2rem;
    }

    .gh-empty p {
        font-size: 0.8rem;
        color: #64748b;
        margin: 0;
    }

    /* ── GUARDIAN SECTION DIVIDER ── */
    .gh-section-divider {
        border: none;
        border-top: 1px solid #e2e8f0;
        margin: 1rem 0 1.5rem;
    }

    .container {
        background: white;
        padding: 35px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, .12);
        margin-bottom: 2rem;
    }

    .container h1 {
        margin-top: 0;
        margin-bottom: 1.5rem;
        font-size: 1.5rem;
        color: #0f172a;
    }

    .form-group {
        margin-bottom: 18px;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .container label {
        font-weight: 600;
        font-size: 0.85rem;
        color: #334155;
    }

    .container input,
    .container textarea,
    .container select {
        padding: 10px;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        width: 100%;
        font-family: inherit;
        font-size: 0.9rem;
        color: #0f172a;
        box-sizing: border-box;
        transition: border-color 0.15s, box-shadow 0.15s;
    }

    .container input:focus,
    .container textarea:focus,
    .container select:focus {
        outline: none;
        border-color: #ec4899;
        box-shadow: 0 0 0 3px rgba(236, 72, 153, 0.15);
    }

    .container textarea {
        min-height: 120px;
        resize: vertical;
    }

    .container button[type="submit"] {
        padding: 12px;
        border: none;
        border-radius: 6px;
        width: 100%;
        background-color: #ec4899;
        color: white;
        font-weight: 700;
        font-size: 0.95rem;
        cursor: pointer;
        transition: background-color 0.2s;
        box-shadow: 0 4px 6px -1px rgba(236, 72, 153, 0.2);
    }

    .container button[type="submit"]:hover {
        background-color: #be185d;
    }
</style>

<div class="gh-profile">

    <!-- ═══════════════════════════════════════════
         LEFT SIDEBAR — PROFILE
         ═══════════════════════════════════════════ -->
    <aside class="gh-sidebar">
        <div class="gh-avatar-wrap" onclick="document.getElementById('profilePhotoInput').click()" title="Change profile photo">
            <img class="gh-avatar" id="profileAvatar"
                src="{{#if user.photoUrl}}{{user.photoUrl}}{{else}}data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' fill='%23f1f5f9'/%3E%3Ctext x='50' y='62' font-size='48' text-anchor='middle'%3E🐾%3C/text%3E%3C/svg%3E{{/if}}"
                alt="{{user.name}}'s profile photo">
            <div class="gh-avatar-cam">
                <div class="gh-avatar-cam-icon">📷</div>
            </div>
            <div class="gh-emoji-status" title="MeoW Guardian">🐾</div>
        </div>
        <input type="file" id="profilePhotoInput" accept="image/*" style="display:none">

        <h1 class="gh-display-name">{{user.name}}</h1>
        <p class="gh-username">{{user.email}}</p>

        <p class="gh-bio">Keeping my cats safe with MeoW's emergency backup protocol</p>

        <div class="gh-stats">
            <a href="#">
                <span class="stat-count">{{cats.length}}</span> cats
            </a>
            <span class="stat-dot">·</span>
            <a href="#">
                <span class="stat-count">{{guardians.length}}</span> guardians
            </a>
        </div>

        <ul class="gh-detail-list">
            {{#if user.phone}}
            <li>
                <span class="detail-icon">📞</span>
                {{user.phone}}
            </li>
            {{/if}}
            <li>
                <span class="detail-icon">📧</span>
                {{user.email}}
            </li>
            <li>
                <span class="detail-icon">🐾</span>
                MeoW Safety Network
            </li>
        </ul>

    </aside>

    <!-- ═══════════════════════════════════════════
         RIGHT CONTENT — CATS & GUARDIANS
         ═══════════════════════════════════════════ -->
    <div class="gh-content">

        <!-- Tab bar -->
        <div class="gh-section-bar">
            <span class="gh-tab active" onclick="showOverview()">
                <span class="tab-icon"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg></span>
                Overview
            </span>
            <span class="gh-tab" onclick="showCats()">
                <span class="tab-icon"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="3.5" r="1.5"/><circle cx="15" cy="3.5" r="1.5"/><circle cx="4.5" cy="8.5" r="1.5"/><circle cx="19.5" cy="8.5" r="1.5"/><path d="M9 12c-2.5 0-5 2-5 6 0 2.5 2 3 4 3 1.5 0 3-0.5 4-0.5s2.5 0.5 4 0.5c2 0 4-0.5 4-3 0-4-2.5-6-5-6-1.5 0-2.5 0.5-3 0.5S10.5 12 9 12z"/></svg></span>
                Cats
                {{#if hasCats}}
                <span class="tab-count">{{cats.length}}</span>
                {{/if}}
            </span>
            <span class="gh-tab" onclick="showGuardians()">
                <span class="tab-icon"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span>
                Guardians
                {{#if hasGuardians}}
                <span class="tab-count">{{guardians.length}}</span>
                {{/if}}
            </span>
        </div>

        {{#if error}}
        <div style="display:flex;align-items:center;gap:0.75rem;background:#fef2f2;border:1px solid #fca5a5;color:#991b1b;padding:0.85rem 1.1rem;border-radius:0.75rem;margin-bottom:1.25rem;font-size:0.875rem;font-weight:500;">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span><strong>Something went wrong:</strong> {{error}}</span>
        </div>
        {{/if}}

        <!-- ── Registered Cats ── -->
        <div id="Overview">
            <div class="gh-section-title">
                <h3>Registered Cats</h3>
            </div>

            {{#if hasCats}}
            <div class="gh-repo-grid">
                {{#each cats}}
                <div class="gh-repo-card" style="display:flex;flex-direction:row;gap:0.9rem;align-items:center;padding:0.85rem 1rem;">
                    {{#if this.photoUrl}}
                    <img src="{{this.photoUrl}}" style="width:44px;height:44px;border-radius:8px;object-fit:cover;border:1px solid #e2e8f0;flex-shrink:0;" alt="{{this.name}}">
                    {{else}}
                    <div style="width:44px;height:44px;border-radius:8px;background:linear-gradient(135deg,#fce7f3,#f5f3ff);display:flex;align-items:center;justify-content:center;flex-shrink:0;border:1px solid #e2e8f0;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#ec4899" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="3.5" r="1.5"/><circle cx="15" cy="3.5" r="1.5"/><circle cx="4.5" cy="8.5" r="1.5"/><circle cx="19.5" cy="8.5" r="1.5"/><path d="M9 12c-2.5 0-5 2-5 6 0 2.5 2 3 4 3 1.5 0 3-0.5 4-0.5s2.5 0.5 4 0.5c2 0 4-0.5 4-3 0-4-2.5-6-5-6-1.5 0-2.5 0.5-3 0.5S10.5 12 9 12z"/></svg>
                    </div>
                    {{/if}}
                    <div style="flex-grow:1;min-width:0;">
                        <div style="display:flex;align-items:center;justify-content:space-between;gap:0.5rem;">
                            <a href="/cats/{{this.name}}" style="font-size:0.92rem;font-weight:700;color:#ec4899;text-decoration:none;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{this.name}}</a>
                            {{#if this.isActiveBackupProtocol}}
                            <span class="repo-visibility" style="flex-shrink:0;">Protected</span>
                            {{/if}}
                        </div>
                        <div style="display:flex;align-items:center;gap:0.6rem;margin-top:0.3rem;flex-wrap:wrap;">
                            {{#if this.breed}}<span style="font-size:0.75rem;color:#64748b;">{{this.breed}}</span>{{/if}}
                            {{#if this.gender}}<span style="font-size:0.75rem;color:#94a3b8;">·</span><span style="font-size:0.75rem;color:#64748b;">{{this.gender}}</span>{{/if}}
                            {{#if this.age}}<span style="font-size:0.75rem;color:#94a3b8;">·</span><span style="font-size:0.75rem;color:#64748b;">{{this.age}} yrs</span>{{/if}}
                        </div>
                    </div>
                </div>
                {{/each}}
            </div>

            {{else}}
            <div class="gh-empty">
                <div class="empty-icon"></div>
                <h4>No cats registered yet</h4>
                <p>Register your first cat to activate the MeoW emergency safety protocol.</p>
