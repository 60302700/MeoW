<style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

    /* ==========================================
       GITHUB-STYLE PROFILE LAYOUT
       ========================================== */
    .gh-profile {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        margin: 50px;
        display: grid;
        grid-template-columns: 296px 1fr;
        gap: 2rem;
        align-items: start;
        height: 900px;
    }

    @media (max-width: 820px) {
        .gh-profile {
            grid-template-columns: 1fr;
            padding: 1rem;
        }
    }

    /* ── LEFT SIDEBAR ── */
    .gh-sidebar {
        position: sticky;
        top: 80px;
    }

    .gh-avatar-wrap {
        position: relative;
        margin-bottom: 1rem;
    }

    .gh-avatar {
        width: 100%;
        aspect-ratio: 1 / 1;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid rgba(236, 72, 153, 0.15);
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
        transition: box-shadow 0.3s ease;
    }

    .gh-avatar:hover {
        box-shadow: 0 8px 30px rgba(236, 72, 153, 0.2);
    }

    .gh-emoji-status {
        position: absolute;
        bottom: 8%;
        right: 8%;
        width: 40px;
        height: 40px;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        cursor: default;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .gh-display-name {
        font-size: 1.5rem;
        font-weight: 800;
        color: #0f172a;
        margin: 0;
        line-height: 1.3;
    }

    .gh-username {
        font-size: 1.15rem;
        font-weight: 400;
        color: #64748b;
        margin: 0 0 0.75rem;
    }

    .gh-bio {
        font-size: 0.875rem;
        color: #334155;
        margin-bottom: 1rem;
        line-height: 1.5;
    }

    .gh-edit-btn {
        width: 100%;
        padding: 0.45rem 1rem;
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        background: #f8fafc;
        color: #334155;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s, border-color 0.2s;
        margin-bottom: 1rem;
    }

    .gh-edit-btn:hover {
        background: #f1f5f9;
        border-color: #cbd5e1;
    }

    /* Stats row */
    .gh-stats {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.8rem;
        color: #64748b;
        margin-bottom: 1rem;
        flex-wrap: wrap;
    }

    .gh-stats a {
        color: inherit;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.3rem;
        transition: color 0.2s;
    }

    .gh-stats a:hover {
        color: #ec4899;
    }

    .gh-stats .stat-count {
        font-weight: 700;
        color: #0f172a;
    }

    .gh-stats .stat-dot {
        color: #cbd5e1;
    }

    /* Sidebar detail items */
    .gh-detail-list {
        list-style: none;
        padding: 0;
        margin: 0 0 1rem;
    }

    .gh-detail-list li {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        font-size: 0.8rem;
        color: #334155;
        padding: 0.25rem 0;
    }

    .gh-detail-list li .detail-icon {
        color: #94a3b8;
        font-size: 0.9rem;
        width: 1.2rem;
        text-align: center;
        flex-shrink: 0;
    }

    /* Achievements / badges */
    .gh-badges {
        border-top: 1px solid #e2e8f0;
        padding-top: 1rem;
        margin-top: 0.5rem;
    }

    .gh-badges h4 {
        font-size: 0.75rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0 0 0.65rem;
    }

    .badge-row {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .gh-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.25rem 0.65rem;
        border-radius: 999px;
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        border: 1px solid;
    }

    .badge-guardian {
        background: #fdf2f8;
        border-color: #fbcfe8;
        color: #be185d;
    }

    .badge-protocol {
        background: #f0fdf4;
        border-color: #bbf7d0;
        color: #166534;
    }

    /* ── RIGHT CONTENT AREA ── */
    .gh-content {}

    /* Tab-style section header */
    .gh-section-bar {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        border-bottom: 1px solid #e2e8f0;
        margin-bottom: 1rem;
        padding-bottom: 0;
    }

    .gh-tab {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.6rem 0.25rem;
        font-size: 0.835rem;
        font-weight: 600;
        color: #64748b;
        text-decoration: none;
        border-bottom: 2px solid transparent;
        margin-bottom: -1px;
        transition: color 0.2s, border-color 0.2s;
        cursor: default;
    }

    .gh-tab .tab-icon {
        font-size: 0.95rem;
    }

    .gh-tab .tab-count {
        background: #f1f5f9;
        color: #334155;
        padding: 0.05rem 0.5rem;
        border-radius: 999px;
        font-size: 0.7rem;
        font-weight: 700;
    }

    .gh-tab:hover {
        color: #0f172a;
        cursor: pointer;
    }

    /* Section title row */
    .gh-section-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.75rem;
        margin-top: 0.5rem;
    }

    .gh-section-title h3 {
        font-size: 0.95rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
    }

    .gh-section-title a {
        font-size: 0.75rem;
        color: #ec4899;
        text-decoration: none;
        font-weight: 500;
        transition: text-decoration 0.2s;
    }

    .gh-section-title a:hover {
        text-decoration: underline;
    }

    /* ── REPO-STYLE CAT CARDS (2-col grid) ── */
    .gh-repo-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    @media (max-width: 720px) {
        .gh-repo-grid {
            grid-template-columns: 1fr;
        }
    }

    .gh-repo-card {
        padding: 1rem 1.25rem;
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        background: #ffffff;
        transition: border-color 0.2s;
        display: flex;
        flex-direction: column;
        min-height: 130px;
    }

    .gh-repo-card:hover {
        border-color: #ec4899;
    }

    /* Repo card top row — name + visibility badge */
    .repo-top-row {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        margin-bottom: 0.4rem;
        flex-wrap: wrap;
    }

    .repo-name {
        font-size: 0.9rem;
        font-weight: 700;
        color: #ec4899;
        text-decoration: none;
        transition: text-decoration 0.15s;
        cursor: default;
    }

    .repo-name:hover {
        text-decoration: underline;
    }

    .repo-visibility {
        padding: 0.05rem 0.45rem;
        border: 1px solid #e2e8f0;
        border-radius: 999px;
        font-size: 0.65rem;
        font-weight: 500;
        color: #64748b;
        flex-shrink: 0;
    }

    /* Repo description */
    .repo-desc {
        font-size: 0.78rem;
        color: #64748b;
        line-height: 1.5;
        margin-bottom: auto;
        padding-bottom: 0.75rem;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Repo footer row — language dot + breed + age */
    .repo-footer {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-size: 0.72rem;
        color: #64748b;
        margin-top: auto;
        flex-wrap: wrap;
    }

    .repo-lang {
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    .lang-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    /* Breed-based color dots (cat-themed) */
    .lang-dot.persian {
        background: #f97316;
    }

    .lang-dot.siamese {
        background: #3b82f6;
    }

    .lang-dot.mainecoon {
        background: #8b5cf6;
    }

    .lang-dot.bengal {
        background: #22c55e;
    }

    .lang-dot.ragdoll {
        background: #ec4899;
    }

    .lang-dot.british {
        background: #eab308;
    }

    .lang-dot.abyssinian {
        background: #ef4444;
    }

    .lang-dot.sphynx {
        background: #06b6d4;
    }

    .lang-dot.default-breed {
        background: #ec4899;
    }

    .repo-meta-item {
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }

    /* ── CONTRIBUTION GRAPH SECTION ── */
    .gh-contrib-section {
        margin-top: 1.5rem;
        margin-bottom: 2rem;
    }

    .gh-contrib-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.75rem;
    }

    .gh-contrib-header h3 {
        font-size: 0.95rem;
        font-weight: 400;
        color: #0f172a;
        margin: 0;
    }

    .gh-contrib-header h3 strong {
        font-weight: 700;
    }

    /* The activity grid container */
    .contrib-graph {
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        padding: 1rem 1.25rem;
        background: #ffffff;
        overflow-x: auto;
    }

    .contrib-grid {
        display: flex;
        gap: 3px;
        align-items: flex-end;
    }

    .contrib-col {
        display: flex;
        flex-direction: column;
        gap: 3px;
    }

    .contrib-cell {
        width: 11px;
        height: 11px;
        border-radius: 2px;
        background: #f1f5f9;
        transition: background 0.15s;
    }

    .contrib-cell.l1 {
        background: rgba(236, 72, 153, 0.2);
    }

    .contrib-cell.l2 {
        background: rgba(236, 72, 153, 0.45);
    }

    .contrib-cell.l3 {
        background: rgba(236, 72, 153, 0.7);
    }

    .contrib-cell.l4 {
        background: #ec4899;
    }

    .contrib-months {
        display: flex;
        gap: 3px;
        margin-bottom: 6px;
        padding-left: 30px;
    }

    .contrib-month-label {
        font-size: 0.65rem;
        color: #64748b;
        flex: 1;
        min-width: 40px;
    }

    .contrib-days {
        display: flex;
        flex-direction: column;
        gap: 3px;
        margin-right: 6px;
        padding-top: 0;
    }

    .contrib-day-label {
        font-size: 0.62rem;
        color: #64748b;
        height: 11px;
        display: flex;
        align-items: center;
        line-height: 1;
    }

    .contrib-body {
        display: flex;
    }

    .contrib-legend {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 4px;
        margin-top: 0.65rem;
        font-size: 0.65rem;
        color: #64748b;
    }

    .contrib-legend .contrib-cell {
        width: 11px;
        height: 11px;
    }

    /* ── EMPTY STATE ── */
    .gh-empty {
        text-align: center;
        padding: 2.5rem 1.5rem;
        border: 1px dashed #e2e8f0;
        border-radius: 0.5rem;
        margin-bottom: 2rem;
    }

    .gh-empty .empty-icon {
        font-size: 2.5rem;
        margin-bottom: 0.6rem;
    }

    .gh-empty h4 {
        font-size: 0.95rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0 0 0.2rem;
    }

    .gh-empty p {
        font-size: 0.8rem;
        color: #64748b;
        margin: 0;
    }

    /* ── GUARDIAN SECTION DIVIDER ── */
    .gh-section-divider {
        border: none;
        border-top: 1px solid #e2e8f0;
        margin: 1rem 0 1.5rem;
    }

    .container {
        background: white;
        padding: 35px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, .12);
        margin-bottom: 2rem;
    }

    .container h1 {
        margin-top: 0;
        margin-bottom: 1.5rem;
        font-size: 1.5rem;
        color: #0f172a;
    }

    .form-group {
        margin-bottom: 18px;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .container label {
        font-weight: 600;
        font-size: 0.85rem;
        color: #334155;
    }

    .container input,
    .container textarea,
    .container select {
        padding: 10px;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        width: 100%;
        font-family: inherit;
        font-size: 0.9rem;
        color: #0f172a;
        box-sizing: border-box;
        transition: border-color 0.15s, box-shadow 0.15s;
    }

    .container input:focus,
    .container textarea:focus,
    .container select:focus {
        outline: none;
        border-color: #ec4899;
        box-shadow: 0 0 0 3px rgba(236, 72, 153, 0.15);
    }

    .container textarea {
        min-height: 120px;
        resize: vertical;
    }

    .container button[type="submit"] {
        padding: 12px;
        border: none;
        border-radius: 6px;
        width: 100%;
        background-color: #ec4899;
        color: white;
        font-weight: 700;
        font-size: 0.95rem;
        cursor: pointer;
        transition: background-color 0.2s;
        box-shadow: 0 4px 6px -1px rgba(236, 72, 153, 0.2);
    }

    .container button[type="submit"]:hover {
        background-color: #be185d;
    }
</style>

<div class="gh-profile">

    <!-- ═══════════════════════════════════════════
         LEFT SIDEBAR — PROFILE
         ═══════════════════════════════════════════ -->
    <aside class="gh-sidebar">
        <div class="gh-avatar-wrap">
            <img class="gh-avatar"
                src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQ_ovzWFxZRsy8myw-DrwGzuTM5nM3-ZyQFvQOAHPCvvpB0Za9baiLwej4&s=10"
                alt="{{user.name}}'s profile photo">
            <div class="gh-emoji-status" title="MeoW Guardian">🐾</div>
        </div>

        <h1 class="gh-display-name">{{user.name}}</h1>
        <p class="gh-username">{{user.email}}</p>

        <p class="gh-bio">Keeping my cats safe with MeoW's emergency backup protocol. Every cat deserves a safety net.
            🐱</p>

        <button class="gh-edit-btn" onclick="openEditProfile()">Edit profile</button>

        <div class="gh-stats">
            <a href="#">
                <span class="stat-count">{{cats.length}}</span> cats
            </a>
            <span class="stat-dot">·</span>
            <a href="#">
                <span class="stat-count">{{guardians.length}}</span> guardians
            </a>
        </div>

        <ul class="gh-detail-list">
            {{#if user.phone}}
            <li>
                <span class="detail-icon">📞</span>
                {{user.phone}}
            </li>
            {{/if}}
            <li>
                <span class="detail-icon">📧</span>
                {{user.email}}
            </li>
            <li>
                <span class="detail-icon">🐾</span>
                MeoW Safety Network
            </li>
        </ul>

        <div class="gh-badges">
            <h4>Badges</h4>
            <div class="badge-row">
                <span class="gh-badge badge-guardian">🛡️ Guardian</span>
                {{#if hasCats}}
                <span class="gh-badge badge-protocol">✅ Protected</span>
                {{/if}}
            </div>
        </div>
    </aside>

    <!-- ═══════════════════════════════════════════
         RIGHT CONTENT — CATS & GUARDIANS
         ═══════════════════════════════════════════ -->
    <div class="gh-content">

        <!-- Tab bar -->
        <div class="gh-section-bar">
            <span class="gh-tab active" onclick="showOverview()">
                <span class="tab-icon">🐱</span>
                Overview
            </span>
            <span class="gh-tab" onclick="showCats()">
                <span class="tab-icon">📋</span>
                Cats
                {{#if hasCats}}
                <span class="tab-count">{{cats.length}}</span>
                {{/if}}
            </span>
            <span class="gh-tab" onclick="showGuardians()">
                <span class="tab-icon">🛡️</span>
                Guardians
                {{#if hasGuardians}}
                <span class="tab-count">{{guardians.length}}</span>
                {{/if}}
            </span>
            <span class="gh-tab" onclick="showEmergency()">
                <span class="tab-icon">🚨</span>
                Emergencies
            </span>
        </div>

        {{#if error}}
        <div
            style="background-color: #fef2f2; border: 1px solid #fca5a5; color: #991b1b; padding: 12px; border-radius: 6px; margin-bottom: 20px; font-size: 0.88rem;">
            ⚠️ <strong>Error:</strong> {{error}}
        </div>
        {{/if}}

        <!-- ── Registered Cats ── -->
        <div id="Overview">
            <div class="gh-section-title">
                <h3>Registered Cats</h3>
            </div>

            {{#if hasCats}}
            <div class="gh-repo-grid">
                {{#each cats}}
                <div class="gh-repo-card"
                    style="display: flex; flex-direction: row; gap: 1.25rem; align-items: flex-start;">
                    {{#if this.photoUrl}}
                    <img src="{{this.photoUrl}}"
                        style="width: 60px; height: 60px; border-radius: 8px; object-fit: cover; border: 1px solid #cbd5e1; flex-shrink: 0;"
                        alt="{{this.name}}">
                    {{else}}
                    <div
                        style="width: 60px; height: 60px; border-radius: 8px; background: #f1f5f9; display: flex; align-items: center; justify-content: center; font-size: 1.75rem; flex-shrink: 0; border: 1px solid #cbd5e1;">
                        🐈</div>
                    {{/if}}
                    <div style="flex-grow: 1; min-width: 0; display: flex; flex-direction: column; min-height: 100%;">
                        <div class="repo-top-row">
                            <span class="repo-name"><a href="/cats/{{this.name}}" target="_blank">{{this.name}}</a></span>
                            {{#if this.isActiveBackupProtocol}}
                            <span class="repo-visibility">🟢 Protected</span>
                            {{else}}
                            <span class="repo-visibility">Unprotected</span>
                            {{/if}}
                        </div>

                        <p class="repo-desc">
                            {{#if this.careInstructions.diet}}🍽️ {{this.careInstructions.diet}}{{/if}}
                            {{#if this.careInstructions.medical}} ⚠️ {{this.careInstructions.medical}}{{/if}}
                        </p>

                        <div class="repo-footer">
                            {{#if this.breed}}
                            <span class="repo-lang">
                                <span class="lang-dot default-breed"></span>
                                {{this.breed}}
                            </span>
                            {{/if}}

                            {{#if this.age}}
                            <span class="repo-meta-item">
                                🎂 {{this.age}} yrs
                            </span>
                            {{/if}}

                            {{#if this.qrCodeId}}
                            <span class="repo-meta-item">
                                🔗 {{this.qrCodeId}}
                            </span>
                            {{/if}}

                            {{#if this.careInstructions.vetDetails}}
                            <span class="repo-meta-item">
                                🏥 Vet on file
                            </span>
                            {{/if}}
                        </div>
                    </div>
                </div>
                {{/each}}
            </div>
            {{else}}
            <div class="gh-empty">
                <div class="empty-icon">🐱</div>
                <h4>No cats registered yet</h4>
                <p>Register your first cat to activate the MeoW emergency safety protocol.</p>
            </div>
            {{/if}}

            <!-- ── Trusted Guardians ── -->
            <div>
                <div class="gh-section-title">
                    <h3>Trusted Guardians</h3>
                </div>

                {{#if hasGuardians}}
                <div class="gh-repo-grid">
                    {{#each guardians}}
                    <div class="gh-repo-card">
                        <div class="repo-top-row">
                            <span class="repo-name">{{this.name}}</span>
                            {{#if this.hasAccepted}}
                            <span class="repo-visibility">🟢 Accepted</span>
                            {{else}}
                            <span class="repo-visibility">Pending</span>
                            {{/if}}
                        </div>

                        <p class="repo-desc">
                            Trusted guardian for your cats. {{#if this.phone}}Reachable at {{this.phone}}.{{/if}}
                            {{#if this.email}} Email: {{this.email}}{{/if}}
                        </p>

                        <div class="repo-footer">
                            {{#if this.priorityOrder}}
                            <span class="repo-lang">
                                <span class="lang-dot"
                                    style="background: {{#if (eq this.priorityOrder 1)}}#22c55e{{else}}#3b82f6{{/if}};"></span>
                                Priority #{{this.priorityOrder}}
                            </span>
                            {{/if}}

                            {{#if this.phone}}
                            <span class="repo-meta-item">
                                📞 {{this.phone}}
                            </span>
                            {{/if}}

                            {{#if this.email}}
                            <span class="repo-meta-item">
                                ✉️ Contact
                            </span>
                            {{/if}}
                        </div>
                    </div>
                    {{/each}}
                </div>
                {{else}}
                <div class="gh-empty">
                    <div class="empty-icon">🤝</div>
                    <h4>No guardians assigned</h4>
                    <p>Add trusted people who can respond if your cat triggers an emergency.</p>
                </div>
                {{/if}}

            </div>
        </div>
        <div id="Cats" style="display:none">
            <div class="container">

                <h1>🐱 Cats</h1>

                {{#if hasCats}}
                <div class="gh-section-title">
                    <h3>Your Registered Cats</h3>
                </div>
                <div class="gh-repo-grid">
                    {{#each cats}}
                    <div class="gh-repo-card" style="display: flex; flex-direction: row; gap: 1.25rem; align-items: flex-start;">
                        {{#if this.photoUrl}}
                        <img src="{{this.photoUrl}}"
                            style="width: 60px; height: 60px; border-radius: 8px; object-fit: cover; border: 1px solid #cbd5e1; flex-shrink: 0;"
                            alt="{{this.name}}">
                        {{else}}
                        <div
                            style="width: 60px; height: 60px; border-radius: 8px; background: #f1f5f9; display: flex; align-items: center; justify-content: center; font-size: 1.75rem; flex-shrink: 0; border: 1px solid #cbd5e1;">
                            🐈</div>
                        {{/if}}
                        <div style="flex-grow: 1; min-width: 0; display: flex; flex-direction: column; min-height: 100%;">
                            <div class="repo-top-row">
                                <span class="repo-name">{{this.name}}</span>
                                {{#if this.isActiveBackupProtocol}}
                                <span class="repo-visibility">🟢 Protected</span>
                                {{else}}
                                <span class="repo-visibility">Unprotected</span>
                                {{/if}}
                            </div>

                            <p class="repo-desc">
                                {{#if this.careInstructions.diet}}🍽️ {{this.careInstructions.diet}}{{/if}}
                                {{#if this.careInstructions.medical}} ⚠️ {{this.careInstructions.medical}}{{/if}}
                            </p>

                            <div class="repo-footer">
                                {{#if this.breed}}
                                <span class="repo-lang">
                                    <span class="lang-dot default-breed"></span>
                                    {{this.breed}}
                                </span>
                                {{/if}}

                                {{#if this.age}}
                                <span class="repo-meta-item">
                                    🎂 {{this.age}} yrs
                                </span>
                                {{/if}}

                                {{#if this.qrCodeId}}
                                <span class="repo-meta-item">
                                    🔗 {{this.qrCodeId}}
                                </span>
                                {{/if}}
                            </div>
                        </div>
                    </div>
                    {{/each}}
                </div>
                {{else}}
                <div class="gh-empty">
                    <div class="empty-icon">🐱</div>
                    <h4>No cats registered yet</h4>
                    <p>Use the form below to add your first cat.</p>
                </div>
                {{/if}}

                <div class="gh-section-title" style="margin-top: 2rem;">
                    <h3>Add a New Cat</h3>
                </div>

                <form id="catForm" method="POST" action="/cats" enctype="multipart/form-data">

                    <div class="form-group">
                        <label>Cat Name</label>
                        <input type="text" id="name" name="name" required>
                    </div>

                    <div class="form-group">
                        <label>Breed</label>
                        <input type="text" id="breed" name="breed" required>
                    </div>

                    <div class="form-group">
                        <label>Age</label>
                        <input type="number" id="age" name="age" min="0" required>
                    </div>

                    <div class="form-group">
                        <label>Photo</label>
                        <input type="file" id="photoInput" name="photo" accept="image/*">
                    </div>

                    <div class="form-group">
                        <label>Care Instructions</label>
                        <textarea id="careInstructions" name="care"
                            placeholder="Diet, medication, vet details, emergency contacts..."></textarea>
                    </div>
                    <button type="submit">
                        Create Cat
                    </button>

                </form>
            </div>
        </div>

        <div id="Guardians" style="display:none">
            <div class="container">
                <h1>🛡️ Guardian Search</h1>

                <div class="gh-section-title" style="margin-bottom: 1rem;">
                    <h3>Find account holders to add as guardians</h3>
                    <p style="margin: 0.35rem 0 0; color: #475569; font-size: 0.92rem;">
                        Search users who already have an account, then select the right guardian from the results.
                    </p>
                </div>

                <div class="form-group">
                    <label for="guardianSearch">Search by name</label>
                    <input type="text" id="guardianSearch" placeholder="Start typing a user name..." style="width:100%;padding:0.75rem 1rem;border:2px solid #e2e8f0;border-radius:0.75rem;font-size:0.95rem;color:#0f172a;outline:none;box-sizing:border-box;">
                </div>

                <div id="guardianSearchInfo" style="margin-bottom: 1rem; color: #475569; font-size: 0.92rem;">Enter a name to search registered users for guardian selection.</div>

                <div id="guardianSearchResults" style="margin-bottom: 1.5rem;">
                    {{#if hasGuardians}}
                    <div id="guardianCards" class="gh-repo-grid">
                        {{#each guardians}}
                        <div class="gh-repo-card guardian-card" data-guardian-name="{{this.name}}" style="display:flex;flex-direction:column;gap:0.75rem;">
                            <div class="repo-top-row">
                                <span class="repo-name">{{this.name}}</span>
                                {{#if this.hasAccepted}}
                                <span class="repo-visibility">🟢 Accepted</span>
                                {{else}}
                                <span class="repo-visibility">Pending</span>
                                {{/if}}
                            </div>
                            <p class="repo-desc">
                                {{#if this.phone}}📞 {{this.phone}}{{/if}}{{#if this.email}} ✉️ {{this.email}}{{/if}}
                            </p>
                        </div>
                        {{/each}}
                    </div>
                    {{else}}
                    <div class="gh-empty">
                        <div class="empty-icon">🤝</div>
                        <h4>No guardians assigned yet</h4>
                        <p>Search for account holders and add them as guardians once the backend is ready.</p>
                    </div>
                    {{/if}}
                    <div id="guardianSearchEmpty" style="display:none;margin-top:1rem;color:#7c3aed;font-size:0.95rem;">No matching users found.</div>
                </div>

                <div class="gh-section-title" style="margin-top: 1rem;">
                    <h3>Your Current Guardians</h3>
                </div>

                {{#if hasGuardians}}
                <div class="gh-repo-grid">
                    {{#each guardians}}
                    <div class="gh-repo-card" style="display:flex;flex-direction:column;gap:0.75rem;">
                        <div class="repo-top-row">
                            <span class="repo-name">{{this.name}}</span>
                            {{#if this.hasAccepted}}
                            <span class="repo-visibility">🟢 Accepted</span>
                            {{else}}
                            <span class="repo-visibility">Pending</span>
                            {{/if}}
                        </div>
                        <p class="repo-desc">
                            {{#if this.phone}}📞 {{this.phone}}{{/if}}{{#if this.email}} ✉️ {{this.email}}{{/if}}
                        </p>
                    </div>
                    {{/each}}
                </div>
                {{else}}
                <div class="gh-empty">
                    <div class="empty-icon">🤝</div>
                    <h4>No guardians assigned yet</h4>
                    <p>Once you search and select a user, assigned guardians will appear here.</p>
                </div>
                {{/if}}
            </div>
        </div>

        <div id="Emergency" style="display:none">
            <div class="container">
                <h1>🚨 Emergencies &amp; System Simulator</h1>

                <div
                    style="background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 15px; margin-bottom: 25px;">
                    <h3 style="color: #991b1b; margin-top: 0; font-size: 0.95rem;">👮 Scanner Portal Simulation</h3>
                    <p style="font-size: 0.82rem; color: #7f1d1d; line-height: 1.4; margin-bottom: 15px;">
                        Test your setup! Choose one of your registered cats below to simulate scanning their QR Code.
                        This will redirect you to the dispatcher console where you can claim care and dispatch alert
                        notifications.
                    </p>
                    <form method="POST" action="/scan" target="_blank">
                        <div class="form-group">
                            <label for="sim-qr" style="color: #7f1d1d;">Select Pet to Simulate Scan</label>
                            <select id="sim-qr" name="qrCodeId" required
                                style="border-color: #fca5a5; background: #fff5f5;">
                                <option value="" disabled selected>Choose a cat...</option>
                                {{#each cats}}
                                <option value="{{this.qrCodeId}}">🐈 {{this.name}} (ID: {{this.qrCodeId}})</option>
                                {{/each}}
                            </select>
                        </div>
                        <button type="submit"
                            style="background-color: #dc2626; color: white; border: none; padding: 10px; border-radius: 5px; font-weight: bold; cursor: pointer; width: 100%;">
                            Dispatch Simulated QR Scan ⚡
                        </button>
                    </form>
                </div>

                <div style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 15px;">
                    <h3 style="color: #334155; margin-top: 0; font-size: 0.95rem;">⚙️ Arm / Disarm Backup Protocol</h3>
                    <p style="font-size: 0.82rem; color: #475569; line-height: 1.4; margin-bottom: 15px;">
                        Arm the safety protocol for individual pets. When armed, scanning their tags will activate
                        notification alerts for their guardians.
                    </p>
                    <form method="POST" action="/cats/toggle-protocol">
                        <div class="form-group">
                            <label for="toggle-cat-id">Select Pet</label>
                            <select id="toggle-cat-id" name="catId" required>
                                <option value="" disabled selected>Choose a cat...</option>
                                {{#each cats}}
                                <option value="{{this._id}}">🐈 {{this.name}} (Currently: {{#if
                                    this.isActiveBackupProtocol}}Armed 🟢{{else}}Disarmed 🔴{{/if}})</option>
                                {{/each}}
                            </select>
                        </div>
                        <button type="submit"
                            style="background-color: #0f172a; color: white; border: none; padding: 10px; border-radius: 5px; font-weight: bold; cursor: pointer; width: 100%;">
                            Toggle Armed Status
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <script>
            // Generate the GitHub-style activity grid with random paw-print activity
            (function () {
                const grid = document.getElementById('activityGrid');
                if (!grid) return;

                const weeks = 52;
                for (let w = 0; w < weeks; w++) {
                    const col = document.createElement('div');
                    col.className = 'contrib-col';
                    for (let d = 0; d < 3; d++) {
                        const cell = document.createElement('div');
                        cell.className = 'contrib-cell';
                        const r = Math.random();
                        if (r > 0.82) cell.classList.add('l4');
                        else if (r > 0.7) cell.classList.add('l3');
                        else if (r > 0.55) cell.classList.add('l2');
                        else if (r > 0.35) cell.classList.add('l1');
                        col.appendChild(cell);
                    }
                    grid.appendChild(col);
                }
            })();

            function showOverview() {
                document.getElementById('Overview').style.display = 'block';
                document.getElementById('Cats').style.display = 'none';
                document.getElementById('Guardians').style.display = 'none';
                document.getElementById('Emergency').style.display = 'none';
            }

            function showCats() {
                document.getElementById('Overview').style.display = 'none';
                document.getElementById('Cats').style.display = 'block';
                document.getElementById('Guardians').style.display = 'none';
                document.getElementById('Emergency').style.display = 'none';
            }

            function showGuardians() {
                document.getElementById('Overview').style.display = 'none';
                document.getElementById('Guardians').style.display = 'block';
                document.getElementById('Cats').style.display = 'none';
                document.getElementById('Emergency').style.display = 'none';
            }

            function showEmergency() {
                document.getElementById('Overview').style.display = 'none';
                document.getElementById('Emergency').style.display = 'block';
                document.getElementById('Cats').style.display = 'none';
                document.getElementById('Guardians').style.display = 'none';
            }

            function initGuardianSearch() {
                const input = document.getElementById('guardianSearch');
                const cards = Array.from(document.querySelectorAll('.guardian-card'));
                const emptyMessage = document.getElementById('guardianSearchEmpty');
                if (!input || cards.length === 0) return;

                input.addEventListener('input', () => {
                    const query = input.value.trim().toLowerCase();
                    let matchCount = 0;

                    cards.forEach(card => {
                        const name = card.dataset.guardianName.toLowerCase();
                        const visible = query === '' || name.includes(query);
                        card.style.display = visible ? 'flex' : 'none';
                        if (visible) matchCount += 1;
                    });

                    const status = document.getElementById('guardianSearchInfo');
                    if (status) {
                        if (query === '') {
                            status.textContent = 'Type a guardian name to filter the list below.';
                        } else if (matchCount === 0) {
                            status.textContent = 'No guardians match that search term.';
                        } else {
                            status.textContent = `${matchCount} guardian${matchCount === 1 ? '' : 's'} found.`;
                        }
                    }

                    if (emptyMessage) {
                        emptyMessage.style.display = query !== '' && matchCount === 0 ? 'block' : 'none';
                    }
                });
            }

            function openEditProfile() {
                document.getElementById('editProfileModal').style.display = 'flex';
                document.body.style.overflow = 'hidden';
            }
            function closeEditProfile() {
                document.getElementById('editProfileModal').style.display = 'none';
                document.body.style.overflow = '';
            }
            document.getElementById('editProfileModal').addEventListener('click', function (e) {
                if (e.target === this) closeEditProfile();
            });

            // Show success toast if ?success=profile in URL
            (function () {
                const params = new URLSearchParams(window.location.search);
                if (params.get('success') === 'profile') {
                    const toast = document.createElement('div');
                    toast.style.cssText = 'position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);background:white;border-radius:0.85rem;padding:0.9rem 1.5rem;box-shadow:0 8px 30px rgba(0,0,0,0.1);font-size:0.9rem;font-weight:600;color:#166534;z-index:9999;border-left:4px solid #22c55e;white-space:nowrap;';
                    toast.textContent = '✅ Profile updated successfully!';
                    document.body.appendChild(toast);
                    setTimeout(() => toast.remove(), 3500);
                    window.history.replaceState({}, '', '/homepage');
                }
            })();

            initGuardianSearch();
        </script>

        <!-- ── Edit Profile Modal ─────────────────────────────────────────── -->
        <div id="editProfileModal"
            style="display:none;position:fixed;inset:0;background:rgba(15,23,42,0.6);backdrop-filter:blur(6px);z-index:8000;align-items:center;justify-content:center;">
            <div
                style="background:white;border-radius:1.5rem;padding:2rem;width:90%;max-width:440px;box-shadow:0 25px 60px rgba(0,0,0,0.15);position:relative;max-height:90vh;overflow-y:auto;">
                <button onclick="closeEditProfile()"
                    style="position:absolute;top:1rem;right:1rem;background:none;border:none;font-size:1.3rem;cursor:pointer;color:#94a3b8;line-height:1;">✕</button>

                <h2 style="font-size:1.25rem;font-weight:800;color:#0f172a;margin:0 0 0.25rem;">Edit Profile</h2>
                <p style="font-size:0.8rem;color:#64748b;margin:0 0 1.5rem;">Leave password fields blank to keep your
                    current password.</p>

                <form method="POST" action="/profile/edit">
                    <div style="margin-bottom:1rem;">
                        <label
                            style="display:block;font-size:0.78rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.04em;margin-bottom:0.35rem;">Full
                            Name</label>
                        <input type="text" name="name" value="{{user.name}}" required
                            style="width:100%;padding:0.75rem 1rem;border:2px solid #e2e8f0;border-radius:0.75rem;font-size:0.95rem;color:#0f172a;outline:none;box-sizing:border-box;transition:border-color 0.2s;"
                            onfocus="this.style.borderColor='#ec4899'" onblur="this.style.borderColor='#e2e8f0'">
                    </div>

                    <div style="margin-bottom:1rem;">
                        <label
                            style="display:block;font-size:0.78rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.04em;margin-bottom:0.35rem;">Phone</label>
                        <input type="tel" name="phone" value="{{user.phone}}"
                            style="width:100%;padding:0.75rem 1rem;border:2px solid #e2e8f0;border-radius:0.75rem;font-size:0.95rem;color:#0f172a;outline:none;box-sizing:border-box;transition:border-color 0.2s;"
                            onfocus="this.style.borderColor='#ec4899'" onblur="this.style.borderColor='#e2e8f0'">
                    </div>

                    <hr style="border:none;border-top:1px solid #e2e8f0;margin:1.25rem 0;">
                    <p
                        style="font-size:0.78rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.04em;margin:0 0 0.75rem;">
                        Change Password (optional)</p>

                    <div style="margin-bottom:1rem;">
                        <label
                            style="display:block;font-size:0.78rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.04em;margin-bottom:0.35rem;">Current
                            Password</label>
                        <input type="password" name="currentPassword"
                            style="width:100%;padding:0.75rem 1rem;border:2px solid #e2e8f0;border-radius:0.75rem;font-size:0.95rem;color:#0f172a;outline:none;box-sizing:border-box;transition:border-color 0.2s;"
                            onfocus="this.style.borderColor='#ec4899'" onblur="this.style.borderColor='#e2e8f0'">
                    </div>

                    <div style="margin-bottom:1rem;">
                        <label
                            style="display:block;font-size:0.78rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.04em;margin-bottom:0.35rem;">New
                            Password</label>
                        <input type="password" name="newPassword" minlength="6"
                            style="width:100%;padding:0.75rem 1rem;border:2px solid #e2e8f0;border-radius:0.75rem;font-size:0.95rem;color:#0f172a;outline:none;box-sizing:border-box;transition:border-color 0.2s;"
                            onfocus="this.style.borderColor='#ec4899'" onblur="this.style.borderColor='#e2e8f0'">
                    </div>

                    <div style="margin-bottom:1.5rem;">
                        <label
                            style="display:block;font-size:0.78rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.04em;margin-bottom:0.35rem;">Confirm
                            New Password</label>
                        <input type="password" name="confirmNewPassword" minlength="6"
                            style="width:100%;padding:0.75rem 1rem;border:2px solid #e2e8f0;border-radius:0.75rem;font-size:0.95rem;color:#0f172a;outline:none;box-sizing:border-box;transition:border-color 0.2s;"
                            onfocus="this.style.borderColor='#ec4899'" onblur="this.style.borderColor='#e2e8f0'">
                    </div>

                    <div style="display:flex;gap:0.75rem;">
                        <button type="button" onclick="closeEditProfile()"
                            style="flex:1;padding:0.85rem;background:none;border:2px solid #e2e8f0;border-radius:0.75rem;font-size:0.9rem;font-weight:600;color:#64748b;cursor:pointer;">
                            Cancel
                        </button>
                        <button type="submit"
                            style="flex:2;padding:0.85rem;background:linear-gradient(135deg,#ec4899,#a855f7);color:white;border:none;border-radius:0.75rem;font-size:0.95rem;font-weight:700;cursor:pointer;box-shadow:0 4px 18px rgba(236,72,153,0.3);">
                            Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>