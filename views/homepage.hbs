                        {{#if this.photoUrl}}
                        <img src="{{this.photoUrl}}" alt="{{this.name}}"
                            style="width:44px;height:44px;border-radius:50%;object-fit:cover;border:1px solid #e2e8f0;flex-shrink:0;">
                        {{else}}
                        <div style="width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,#ec4899,#a855f7);color:white;display:flex;align-items:center;justify-content:center;font-size:0.95rem;font-weight:800;flex-shrink:0;">{{initial this.name}}</div>
                        {{/if}}
                        <div style="flex-grow: 1; min-width: 0; display: flex; flex-direction: column; min-height: 100%;">
                            <div class="repo-top-row">
                                <span class="repo-name">{{this.name}}</span>
                                <div style="display:flex;align-items:center;gap:0.5rem;">
                                    {{#if this.hasAccepted}}
                                    <span class="repo-visibility" style="background:#f0fdf4;border-color:#bbf7d0;color:#166534;">✓ Accepted</span>
                                    {{else}}
                                    <span class="repo-visibility" style="background:#fffbeb;border-color:#fde68a;color:#92400e;">⏳ Pending</span>
                                    {{/if}}
                                    <button onclick="openEditGuardian('{{this.Id}}')"
                                        style="background:none;border:1.5px solid #e2e8f0;border-radius:0.5rem;padding:0.2rem 0.6rem;font-size:0.75rem;font-weight:600;color:#64748b;cursor:pointer;transition:all 0.15s;"
                                        onmouseover="this.style.borderColor='#ec4899';this.style.color='#ec4899'" onmouseout="this.style.borderColor='#e2e8f0';this.style.color='#64748b'">Edit</button>
