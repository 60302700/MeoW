<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>Login - MeoW Safety Net</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
</head>

<body>

    <!-- 1. Global Navbar: Sitting completely separate at the top of the body screen -->
    <header class="global-navbar">
        <div class="navbar-brand">
            <h3>Me<svg viewBox="0 0 64 64"
                    style="display:inline-block; width:0.85em; height:0.85em; vertical-align:-0.1em;"
                    aria-hidden="true">
                    <g fill="#ec4899">
                        <ellipse cx="32" cy="42" rx="17" ry="14" />
                        <ellipse cx="13" cy="24" rx="8" ry="10" transform="rotate(-20 13 24)" />
                        <ellipse cx="26" cy="13" rx="8" ry="10" transform="rotate(-5 26 13)" />
                        <ellipse cx="41" cy="13" rx="8" ry="10" transform="rotate(8 41 13)" />
                        <ellipse cx="53" cy="25" rx="8" ry="10" transform="rotate(22 53 25)" />
                    </g>
                </svg>W</h3>
        </div>
        <nav>
            <ul>
                <li><a href="/register">Register</a></li>
                <li><a href="/emergency">🚨 Emergency</a></li>
            </ul>
        </nav>
    </header>

    <!-- 2. Main Content Wrapper Area -->
    <main class="main-content">

        <!-- Independent Login Card Container -->
        <div class="card max-w-md">
            <div class="card-body">

                <form action="/login" method="POST" class="space-y-4">

                    <div class="text-center mb-6">
                        <h1 class="title-xl">Sign In</h1>
                    </div>

                    {{#if error}}
                    <p class="alert-box alert-warning text-center">{{error}}</p>
                    {{/if}}

                    <div class="form-group">
                        <input type="text" name="email" placeholder="Email" class="input-field" required
                            value="{{values.email}}">
                    </div>

                    <div class="form-group">
                        <input type="password" name="password" placeholder="Password" class="input-field" required>
                    </div>

                    <button type="submit" class="btn btn-teal">
                        Login
                    </button>

                </form>

            </div>
        </div>

    </main>

</body>

</html>