<div class="glass-card max-w-md" style="width:100%;max-width:420px;">
    <div class="header-bar bg-slate-dark" style="border-radius:1rem 1rem 0 0;margin:-2rem -2rem 2rem;">
        Set New Password
    </div>

    {{#if success}}
    <div style="background:#f0fdf4;border-left:4px solid #22c55e;color:#166534;padding:0.75rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:600;margin-bottom:1.25rem;">
        ✅ Password updated successfully!
    </div>
    <a href="/login" class="btn-step-next" style="display:block;text-align:center;text-decoration:none;margin-top:0.5rem;">
        Sign in <span class="btn-arrow">→</span>
    </a>
    {{else}}

    {{#if error}}
        <div class="inline-error">{{error}}</div>
    {{/if}}

    <p style="font-size:0.85rem;color:#64748b;margin-bottom:1.25rem;line-height:1.5;">
        Choose a new password for your account.
    </p>

    <form method="POST" action="/reset-password">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <input type="hidden" name="token" value="{{token}}">
        <div class="floating-field">
            <input type="password" id="newPassword" name="newPassword" class="fancy-input" placeholder=" " required minlength="8" oninput="checkPwStrength('newPassword','pw-rules-reset')">
            <label for="newPassword">New password</label>
        </div>
        <div id="pw-rules-reset" style="display:none;margin-top:0.5rem;margin-bottom:0.75rem;padding:0.65rem 0.85rem;background:#f8fafc;border:1px solid #e2e8f0;border-radius:0.65rem;">
            <p data-rule="len"  style="font-size:0.76rem;margin:0 0 0.2rem;color:#94a3b8;">&#10007; At least 8 characters</p>
            <p data-rule="up"   style="font-size:0.76rem;margin:0 0 0.2rem;color:#94a3b8;">&#10007; One uppercase letter</p>
            <p data-rule="low"  style="font-size:0.76rem;margin:0 0 0.2rem;color:#94a3b8;">&#10007; One lowercase letter</p>
            <p data-rule="num"  style="font-size:0.76rem;margin:0 0 0.2rem;color:#94a3b8;">&#10007; One number</p>
            <p data-rule="spec" style="font-size:0.76rem;margin:0;color:#94a3b8;">&#10007; One special character</p>
        </div>
        <div class="floating-field">
            <input type="password" id="confirmPassword" name="confirmPassword" class="fancy-input" placeholder=" " required minlength="6">
            <label for="confirmPassword">Confirm new password</label>
        </div>

        <button type="submit" class="btn-step-next" style="margin-top:0.5rem;">
            Update Password <span class="btn-arrow">→</span>
        </button>
    </form>

    <p class="login-link" style="margin-top:1.5rem;">
        <a href="/forgot-password">Request a new link</a>
    </p>
    {{/if}}
</div>
<script nonce="{{nonce}}">
function checkPwStrength(inputId, rulesId) {
    const val = document.getElementById(inputId).value;
    const box = document.getElementById(rulesId);
    box.style.display = val.length > 0 ? 'block' : 'none';
    const rules = {
        len:  val.length >= 8,
        up:   /[A-Z]/.test(val),
        low:  /[a-z]/.test(val),
        num:  /[0-9]/.test(val),
        spec: /[^A-Za-z0-9]/.test(val),
    };
    box.querySelectorAll('[data-rule]').forEach(el => {
        const ok = rules[el.dataset.rule];
        el.style.color = ok ? '#16a34a' : '#ef4444';
        el.innerHTML = (ok ? '&#10003;' : '&#10007;') + ' ' + el.textContent.slice(2);
    });
}
</script>