<div class="glass-card max-w-md" style="width:100%;max-width:420px;">
    <div class="header-bar bg-slate-dark" style="border-radius:1rem 1rem 0 0;margin:-2rem -2rem 2rem;">
        Set New Password
    </div>

    {{#if success}}
    <div style="background:#f0fdf4;border-left:4px solid #22c55e;color:#166534;padding:0.75rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:600;margin-bottom:1.25rem;">
        ✅ Password updated successfully!
    </div>
    <a href="/login" class="btn-step-next" style="display:block;text-align:center;text-decoration:none;margin-top:0.5rem;">
        Sign in <span class="btn-arrow">→</span>
    </a>
    {{else}}

    {{#if error}}
        <div class="inline-error">{{error}}</div>
    {{/if}}

    <p style="font-size:0.85rem;color:#64748b;margin-bottom:1.25rem;line-height:1.5;">
        Choose a new password for your account.
    </p>

    <form method="POST" action="/reset-password">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <input type="hidden" name="token" value="{{token}}">
        <div class="floating-field">
            <input type="password" id="newPassword" name="newPassword" class="fancy-input" placeholder=" " required minlength="8">
            <label for="newPassword">New password</label>
        </div>
        <p style="font-size:0.72rem;color:#94a3b8;margin:-0.25rem 0 0.75rem;line-height:1.5;">
            Min 8 characters &nbsp;·&nbsp; uppercase &nbsp;·&nbsp; lowercase &nbsp;·&nbsp; number &nbsp;·&nbsp; special character
        </p>
        <div class="floating-field">
            <input type="password" id="confirmPassword" name="confirmPassword" class="fancy-input" placeholder=" " required minlength="6">
            <label for="confirmPassword">Confirm new password</label>
        </div>

        <button type="submit" class="btn-step-next" style="margin-top:0.5rem;">
            Update Password <span class="btn-arrow">→</span>
        </button>
    </form>

    <p class="login-link" style="margin-top:1.5rem;">
        <a href="/forgot-password">Request a new link</a>
    </p>
    {{/if}}
</div>