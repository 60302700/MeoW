<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} — MeoW</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', sans-serif;
            background: #f8fafc;
            min-height: 100vh;
            color: #0f172a;
        }

        /* ── Top bar ── */
        .topbar {
            background: white;
            border-bottom: 1px solid #e2e8f0;
            padding: 0 1.5rem;
            height: 56px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .topbar-brand {
            font-size: 1.1rem;
            font-weight: 900;
            background: linear-gradient(135deg, #9d174d, #ec4899);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .topbar-label {
            font-size: 0.72rem;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }

        /* ── Hero banner ── */
        .hero {
            background: linear-gradient(135deg, #9d174d 0%, #db2777 60%, #a855f7 100%);
            padding: 2.5rem 1.5rem 3.5rem;
            text-align: center;
            position: relative;
        }
        .hero-label {
            display: inline-block;
            background: rgba(255,255,255,0.2);
            color: white;
            font-size: 0.7rem;
            font-weight: 700;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            padding: 0.3rem 0.8rem;
            border-radius: 99px;
            margin-bottom: 0.75rem;
        }
        .hero h1 {
            color: white;
            font-size: 1.6rem;
            font-weight: 900;
            margin-bottom: 0.4rem;
            line-height: 1.2;
        }
        .hero p {
            color: rgba(255,255,255,0.8);
            font-size: 0.9rem;
            line-height: 1.5;
            max-width: 480px;
            margin: 0 auto;
        }
        .hero-wave {
            position: absolute;
            bottom: -1px;
            left: 0;
            right: 0;
        }

        /* ── Main content ── */
        .content {
            max-width: 680px;
            margin: 0 auto;
            padding: 2rem 1.25rem 3rem;
        }

        /* ── Acknowledge card ── */
        .ack-card {
            background: white;
            border-radius: 1.25rem;
            box-shadow: 0 4px 24px rgba(0,0,0,0.07);
            overflow: hidden;
            margin-bottom: 1.5rem;
        }
        .ack-card-body {
            padding: 1.75rem;
        }
        .ack-card h2 {
            font-size: 1.1rem;
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 0.5rem;
        }
        .ack-card p {
            font-size: 0.875rem;
            color: #475569;
            line-height: 1.6;
            margin-bottom: 1.25rem;
        }
        .btn-ack {
            display: block;
            width: 100%;
            padding: 1rem;
            background: linear-gradient(135deg, #9d174d, #ec4899);
            color: white;
            border: none;
            border-radius: 0.875rem;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            text-align: center;
            transition: opacity 0.2s, transform 0.15s;
            letter-spacing: 0.01em;
        }
        .btn-ack:hover { opacity: 0.92; transform: translateY(-1px); }

        .acked-banner {
            padding: 1.75rem;
            text-align: center;
        }
        .acked-icon {
            width: 56px;
            height: 56px;
            background: #f0fdf4;
            border: 2px solid #86efac;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            margin: 0 auto 0.75rem;
        }
        .acked-banner h3 {
            font-size: 1.05rem;
            font-weight: 800;
            color: #166534;
            margin-bottom: 0.3rem;
        }
        .acked-banner p {
            font-size: 0.85rem;
            color: #475569;
        }

        /* ── Section label ── */
        .section-label {
            font-size: 0.7rem;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 0.75rem;
        }

        /* ── Cat card ── */
        .cat-card {
            background: white;
            border-radius: 1.25rem;
            box-shadow: 0 4px 24px rgba(0,0,0,0.07);
            overflow: hidden;
            margin-bottom: 1.25rem;
        }
        .cat-header {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1.25rem 1.5rem;
            border-bottom: 1px solid #f1f5f9;
        }
        .cat-avatar {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            object-fit: cover;
            flex-shrink: 0;
            border: 2px solid #fbcfe8;
        }
        .cat-avatar-placeholder {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: linear-gradient(135deg, #fce7f3, #f5f3ff);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            flex-shrink: 0;
            border: 2px solid #fbcfe8;
        }
        .cat-header-info h3 {
            font-size: 1.05rem;
            font-weight: 800;
            color: #0f172a;
        }
        .cat-header-meta {
            font-size: 0.78rem;
            color: #64748b;
            margin-top: 0.15rem;
        }
        .cat-body {
            padding: 1.25rem 1.5rem;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.75rem;
        }
        @media (max-width: 480px) { .cat-body { grid-template-columns: 1fr; } }

        .care-item {
            background: #f8fafc;
            border-radius: 0.75rem;
            padding: 0.75rem 1rem;
        }
        .care-item.full { grid-column: 1 / -1; }
        .care-item.allergy { background: #fff1f2; }
        .care-item.notes { background: #fffbeb; }
        .care-item-label {
            font-size: 0.68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: #94a3b8;
            margin-bottom: 0.3rem;
        }
        .care-item.allergy .care-item-label { color: #e11d48; }
        .care-item.notes .care-item-label { color: #b45309; }
        .care-item-value {
            font-size: 0.875rem;
            color: #1e293b;
            line-height: 1.5;
            font-weight: 500;
        }

        /* ── Alert boxes ── */
        .alert {
            border-radius: 0.875rem;
            padding: 1rem 1.25rem;
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 1.5rem;
        }
        .alert-error { background: #fef2f2; border-left: 4px solid #ef4444; color: #991b1b; }
        .alert-success { background: #f0fdf4; border-left: 4px solid #22c55e; color: #166534; }

        /* ── Footer ── */
        .footer {
            text-align: center;
            padding: 2rem 1rem;
            font-size: 0.75rem;
            color: #94a3b8;
        }
    </style>
</head>
<body>

    <div class="topbar">
        <span class="topbar-brand">MeoW</span>
        <span class="topbar-label">Guardian Access</span>
    </div>

    {{#if error}}
    <div class="content">
        <div class="alert alert-error">{{error}}</div>
    </div>
    {{else}}

    <div class="hero">
        <span class="hero-label">Guardian Request</span>
        <h1>{{ownerName}} needs your help</h1>
        <p>Review the care instructions below and confirm you are available to look after their cats.</p>
        <svg class="hero-wave" viewBox="0 0 1440 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0 40 C360 0 1080 0 1440 40 L1440 40 L0 40 Z" fill="#f8fafc"/>
        </svg>
    </div>

    <div class="content">

        {{#if acked}}
        <div class="alert alert-success">Your acknowledgement was sent. {{ownerName}} has been notified — thank you!</div>
        {{/if}}

        <!-- Acknowledge / status card -->
        <div class="ack-card" style="margin-bottom:1.75rem;">
            {{#if alreadyAcknowledged}}
            <div class="acked-banner">
                <div class="acked-icon">✓</div>
                <h3>Already acknowledged</h3>
                <p>You confirmed you're looking after {{ownerName}}'s cats. Keep this page bookmarked for reference.</p>
            </div>
            {{else if acked}}
            <div class="acked-banner">
                <div class="acked-icon">✓</div>
                <h3>You're confirmed</h3>
                <p>{{ownerName}} has been notified. A wallet card with full care details has been sent to your email.</p>
            </div>
            {{else}}
            <div class="ack-card-body">
                <h2>Confirm you're available</h2>
                <p>By acknowledging, you confirm you're aware of the situation and will look after these cats. A wallet card with all care details will be sent to your email.</p>
                <form method="POST" action="/guardian-access/{{token}}/acknowledge">
                    <input type="hidden" name="_csrf" value="{{csrfToken}}">
                    <button type="submit" class="btn-ack">I'm on it — Acknowledge</button>
                </form>
            </div>
            {{/if}}
        </div>

        <!-- Cat cards -->
        <p class="section-label">Cats in your care</p>

        {{#each cats}}
        <div class="cat-card">
            <div class="cat-header">
                {{#if this.photoUrl}}
                    <img class="cat-avatar" src="{{this.photoUrl}}" alt="{{this.name}}">
                {{else}}
                    <div class="cat-avatar-placeholder">🐱</div>
                {{/if}}
                <div class="cat-header-info">
                    <h3>{{this.name}}</h3>
                    <div class="cat-header-meta">
                        {{#if this.breed}}{{this.breed}}{{/if}}
                        {{#if this.age}} · {{this.age}} yrs{{/if}}
                        {{#if this.careInstructions.neutered}} · Neutered{{/if}}
                    </div>
                </div>
            </div>
            <div class="cat-body">
                {{#if this.careInstructions.feedingSchedule}}
                <div class="care-item">
                    <div class="care-item-label">Feeding</div>
                    <div class="care-item-value">{{this.careInstructions.feedingSchedule}}{{#if this.careInstructions.foodBrand}} — {{this.careInstructions.foodBrand}}{{/if}}</div>
                </div>
                {{/if}}
                {{#if this.careInstructions.vetName}}
                <div class="care-item">
                    <div class="care-item-label">Vet</div>
                    <div class="care-item-value">{{this.careInstructions.vetName}}{{#if this.careInstructions.vetPhone}}<br><a href="tel:{{this.careInstructions.vetPhone}}" style="color:#9d174d;text-decoration:none;font-weight:600;">{{this.careInstructions.vetPhone}}</a>{{/if}}</div>
                </div>
                {{/if}}
                {{#if this.careInstructions.allergies}}
                <div class="care-item allergy full">
                    <div class="care-item-label">Allergies</div>
                    <div class="care-item-value">{{this.careInstructions.allergies}}</div>
                </div>
                {{/if}}
                {{#if this.careInstructions.conditions}}
                <div class="care-item full">
                    <div class="care-item-label">Medical conditions</div>
                    <div class="care-item-value">{{this.careInstructions.conditions}}</div>
                </div>
                {{/if}}
                {{#if this.careInstructions.medications}}
                <div class="care-item full">
                    <div class="care-item-label">Medications</div>
                    <div class="care-item-value">{{this.careInstructions.medications}}</div>
                </div>
                {{/if}}
                {{#if this.careInstructions.personality}}
                <div class="care-item full">
                    <div class="care-item-label">Personality</div>
                    <div class="care-item-value">{{this.careInstructions.personality}}</div>
                </div>
                {{/if}}
                {{#if this.careInstructions.microchip}}
                <div class="care-item">
                    <div class="care-item-label">Microchip</div>
                    <div class="care-item-value">{{this.careInstructions.microchip}}</div>
                </div>
                {{/if}}
                {{#if this.careInstructions.passportNumber}}
                <div class="care-item">
                    <div class="care-item-label">Passport</div>
                    <div class="care-item-value">{{this.careInstructions.passportNumber}}</div>
                </div>
                {{/if}}
                {{#if this.careInstructions.notes}}
                <div class="care-item notes full">
                    <div class="care-item-label">Notes</div>
                    <div class="care-item-value">{{this.careInstructions.notes}}</div>
                </div>
                {{/if}}
            </div>
        </div>
        {{/each}}

    </div>

    <div class="footer">
        MeoW — Cat Safety Network &nbsp;·&nbsp; This link is private — do not share it
    </div>

    {{/if}}
</body>
</html>