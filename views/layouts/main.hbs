<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <style>
        /* ==========================================
   1. GLOBAL RESETS & FOUNDATION
   ========================================== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: #f1f5f9;
            font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            color: #0f172a;
            width: 100vw;
            min-height: 100vh;

            /* Standard top-to-bottom layout flow */
            display: flex;
            flex-direction: column;
        }

        /* Centering main wrapper area for form cards under the navbar */
        .main-content {
            flex: 1;
            /* Takes up all remaining screen space */
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        /* ==========================================
   2. REUSABLE UTILITY LAYOUT CLASSES
   ========================================== */
        .w-full {
            width: 100%;
        }

        .max-w-md {
            max-width: 28rem;
        }

        .hidden {
            display: none !important;
        }

        .block {
            display: block !important;
        }

        /* Text Alignment & Transformations */
        .text-center {
            text-align: center;
        }

        .text-left {
            text-align: left;
        }

        .text-right {
            text-align: right;
        }

        .uppercase {
            text-transform: uppercase;
        }

        /* Typography Scale */
        .title-xl {
            font-size: 1.875rem;
            font-weight: 900;
            color: #0f172a;
        }

        .title-lg {
            font-size: 1.25rem;
            font-weight: 700;
            color: #1e293b;
        }

        .text-sm {
            font-size: 0.875rem;
        }

        .text-xs {
            font-size: 0.75rem;
        }

        /* Spacing Components (Stacking items cleanly) */
        .space-y-4>*+* {
            margin-top: 1rem;
        }

        .mb-2 {
            margin-bottom: 0.5rem;
        }

        .mb-4 {
            margin-bottom: 1rem;
        }

        .mb-6 {
            margin-bottom: 1.5rem;
        }

        /* Color States */
        .text-slate-600 {
            color: #475569;
        }

        .text-red-600 {
            color: #dc2626;
        }

        /* ==========================================
   3. THE CONTAINER CARD ARCHITECTURE
   ========================================== */
        .card {
            background-color: #ffffff;
            border-radius: 1rem;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            overflow: hidden;
            border: 4px solid transparent;
            transition: all 500ms ease;
            width: 100%;
        }

        .card-body {
            padding: 1.5rem;
            /* Internal container layout padding */
        }

        /* ==========================================
   4. NAVIGATION & HEADERS
   ========================================== */
        .header-bar {
            padding: 1.25rem;
            color: #ffffff;
            font-weight: 700;
            letter-spacing: 0.05em;
            text-align: center;
            text-transform: uppercase;
            transition: background-color 500ms ease;
        }

        /* Header Variations */
        .bg-slate-dark {
            background: linear-gradient(135deg, #9d174d 0%, #ec4899 60%, #f472b6 100%);
        }

        .bg-emergency-red {
            background-color: #dc2626;
        }

        .header-bar a {
            color: #ffffff;
            text-decoration: none;
            font-size: 0.875rem;
            transition: opacity 0.2s;
        }

        .header-bar a:hover {
            opacity: 0.8;
        }

        /* ==========================================
   5. FORM FIELDS & INPUTS
   ========================================== */
        .form-group {
            display: flex;
            flex-direction: column;
            margin: 0;
        }

        .input-field {
            width: 100%;
            box-sizing: border-box;
            font-size: 1rem;
            padding: 0.75rem 1rem;
            border: 2px solid #cbd5e1;
            border-radius: 0.75rem;
            background-color: #ffffff;
            color: #0f172a;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .input-field:focus {
            outline: none;
            border-color: #ec4899;
            /* Calm teal color boundary on focus */
            box-shadow: 0 0 0 4px rgba(236, 72, 153, 0.1);
        }

        /* Special styling wrapper for numeric codes/tokens */
        .input-code {
            text-align: center;
            font-size: 1.5rem;
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, monospace;
            letter-spacing: 0.1em;
        }

        /* ==========================================
   6. ACTIONS & BUTTONS
   ========================================== */
        .btn {
            width: 100%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            padding: 1rem 1.5rem;
            border-radius: 0.75rem;
            border: none;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            transition: all 0.2s ease;
            color: #ffffff;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        .btn:active {
            transform: scale(0.98);
        }

        /* Button Variations */
        .btn-teal {
            background-color: #ec4899;
        }

        .btn-teal:hover {
            background-color: #be185d;
        }

        .btn-red {
            background-color: #dc2626;
            font-weight: 900;
        }

        .btn-red:hover {
            background-color: #b91c1c;
        }

        .btn-orange {
            background-color: #ea580c;
        }

        .btn-orange:hover {
            background-color: #c2410c;
        }

        /* ==========================================
   7. STATUS CALLOUT BLOCKS & BANNERS
   ========================================== */
        .alert-box {
            padding: 1rem;
            border-radius: 0.75rem;
            margin-bottom: 1.5rem;
            font-size: 0.875rem;
        }

        .alert-warning {
            background-color: #fffbeb;
            border-left: 4px solid #d97706;
            color: #92400e;
        }

        .alert-info {
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
            color: #475569;
        }

        /* ==========================================
   8. SYSTEM ANIMATIONS
   ========================================== */
        @keyframes pulse-opacity {

            0%,
            100% {
                opacity: 1;
            }

            50% {
                opacity: .5;
            }
        }

        .animate-pulse {
            animation: pulse-opacity 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }

        @keyframes pulse-border {

            0%,
            100% {
                border-color: rgba(220, 38, 38, 1);
            }

            50% {
                border-color: rgba(220, 38, 38, 0.4);
            }
        }

        .emergency-pulse {
            animation: pulse-border 2s infinite;
        }

        /* Global Navigation Header Bar (Spans full window width) */
        .global-navbar {
            width: 100%;
            background: linear-gradient(135deg, #9d174d 0%, #ec4899 60%, #f472b6 100%);
            border-bottom: 2px solid #ec4899;
            padding: 0.85rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 4px 20px -2px rgba(236, 72, 153, 0.2);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        /* Brand Logo Layout Styles */
        .navbar-brand h3 {
            margin: 0;
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: 0.05em;
        }

        .navbar-brand h3 a {
            text-decoration: none;
            background: linear-gradient(to right, #ffffff, #fce7f3);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            display: inline-block;
            transition: transform 0.3s ease;
        }

        .navbar-brand h3 a:hover {
            transform: scale(1.05);
        }

        /* Paw-print stand-in for the "o" in the MeoW logo */
        .logo-paw {
            display: inline-block;
            width: 0.85em;
            height: 0.85em;
            vertical-align: -0.1em;
        }

        /* Navigation Links Container Alignment */
        .navbar-links ul {
            list-style: none;
            display: flex;
            align-items: center;
            gap: 1.5rem;
            margin: 0;
            padding: 0;
        }

        .navbar-links a {
            color: #fce7f3;
            text-decoration: none;
            font-size: 0.875rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            transition: color 0.3s ease;
            position: relative;
            padding: 0.25rem 0;
        }

        .navbar-links a:hover {
            color: #ffffff;
        }

        /* Nav link hover slide underline effect */
        .navbar-links a::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: -2px;
            left: 0;
            background-color: #ec4899;
            transition: width 0.3s ease;
        }

        .navbar-links a:hover::after {
            width: 100%;
        }

        /* Special style for Emergency link to add dynamic alert coloring */
        .navbar-links a.nav-emergency {
            color: #ffffff;
            padding: 0.5rem 1.1rem;
            border-radius: 0.6rem;
            border: none;
            background: linear-gradient(135deg, #dc2626, #ef4444);
            font-weight: 700;
            letter-spacing: 0.03em;
            box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.6), 0 3px 12px rgba(220, 38, 38, 0.4);
            transition: all 0.2s ease;
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
            animation: emergencyNavPulse 1.8s ease-in-out infinite;
        }

        @keyframes emergencyNavPulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.6), 0 3px 12px rgba(220, 38, 38, 0.35); }
            50%       { box-shadow: 0 0 0 7px rgba(239, 68, 68, 0), 0 3px 18px rgba(220, 38, 38, 0.55); }
        }

        .navbar-links a.nav-emergency::after {
            display: none;
        }

        .navbar-links a.nav-emergency:hover {
            transform: translateY(-2px) scale(1.04);
            background: linear-gradient(135deg, #b91c1c, #dc2626);
            box-shadow: 0 0 0 0 rgba(239, 68, 68, 0), 0 6px 20px rgba(220, 38, 38, 0.55);
        }

        /* ==========================================
   9. EMERGENCY PORTAL COMPONENTS
   ========================================== */
        .flex {
            display: flex;
        }

        .items-center {
            align-items: center;
        }

        .justify-center {
            justify-content: center;
        }

        .space-x-4>*+* {
            margin-left: 1rem;
        }

        .avatar {
            width: 4rem;
            height: 4rem;
            border-radius: 9999px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.875rem;
        }

        .avatar-emergency {
            background-color: #fee2e2;
            border: 2px solid #ef4444;
        }

        /* ==========================================
   11. REGISTER PAGE — LAYOUT
   ========================================== */
        .register-wrapper {
            width: 100%;
            max-width: 1080px;
            padding: 1.5rem 1rem;
            position: relative;
        }

        .register-layout {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
            align-items: start;
        }

        @media (max-width: 820px) {
            .register-layout { grid-template-columns: 1fr; }
            .register-preview-panel { order: -1; }
        }

        /* ==========================================
   12. GLASSMORPHISM CARD
   ========================================== */
        .glass-card {
            background: rgba(255, 255, 255, 0.88);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(236, 72, 153, 0.14);
            border-radius: 1.5rem;
            padding: 2rem;
            box-shadow: 0 20px 60px rgba(236, 72, 153, 0.08), 0 4px 24px rgba(0, 0, 0, 0.05);
        }

        /* ==========================================
   13. PAW PROGRESS INDICATOR
   ========================================== */
        .paw-progress {
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 2rem;
        }

        .paw-step-dot {
            width: 2.4rem;
            height: 2.4rem;
            border-radius: 50%;
            background: #e2e8f0;
            color: #94a3b8;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: background 0.35s, color 0.35s, box-shadow 0.35s;
        }

        .paw-step-dot svg { width: 1.1rem; height: 1.1rem; }

        .paw-step-dot.active {
            background: linear-gradient(135deg, #ec4899, #a855f7);
            color: white;
            box-shadow: 0 0 18px rgba(236, 72, 153, 0.45);
        }

        .paw-progress-line {
            flex: 1;
            max-width: 4rem;
            height: 2px;
            background: #e2e8f0;
            transition: background 0.35s;
        }

        .paw-progress-line.filled {
            background: linear-gradient(to right, #ec4899, #a855f7);
        }

        /* ==========================================
   14. MULTI-STEP FORM
   ========================================== */
        .form-step {
            display: none;
            transition: opacity 0.3s ease, transform 0.3s ease;
        }

        .form-step.active { display: block; }

        .step-header { margin-bottom: 1.5rem; }

        .step-title {
            font-size: 1.45rem;
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 0.3rem;
        }

        .step-sub {
            color: #64748b;
            font-size: 0.88rem;
        }

        .field-group { margin-bottom: 0.5rem; }

        /* ==========================================
   15. FLOATING LABEL INPUTS
   ========================================== */
        .floating-field {
            position: relative;
            margin-bottom: 1.25rem;
        }

        .fancy-input {
            width: 100%;
            padding: 1.1rem 1rem 0.55rem;
            border: 2px solid #e2e8f0;
            border-radius: 0.85rem;
            font-size: 1rem;
            background: #fff;
            color: #0f172a;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
            box-sizing: border-box;
        }

        .fancy-input:focus {
            border-color: #ec4899;
            box-shadow: 0 0 0 4px rgba(236, 72, 153, 0.12);
            transform: scale(1.01);
        }

        .floating-field label {
            position: absolute;
            left: 1rem;
            top: 0.9rem;
            color: #94a3b8;
            font-size: 0.875rem;
            pointer-events: none;
            transition: all 0.2s ease;
        }

        .fancy-input:focus + label,
        .fancy-input:not(:placeholder-shown) + label {
            top: 0.25rem;
            font-size: 0.7rem;
            color: #ec4899;
            font-weight: 700;
            letter-spacing: 0.03em;
            text-transform: uppercase;
        }

        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            20%, 60% { transform: translateX(-6px) scale(1.01); }
            40%, 80% { transform: translateX(6px) scale(1.01); }
        }

        .fancy-input.shake { border-color: #ef4444; animation: shake 0.4s ease; }

        /* ==========================================
   16. STEP NAVIGATION BUTTONS
   ========================================== */
        .btn-step-next {
            width: 100%;
            padding: 0.95rem;
            background: linear-gradient(135deg, #ec4899, #a855f7);
            color: #fff;
            border: none;
            border-radius: 0.85rem;
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            letter-spacing: 0.03em;
            box-shadow: 0 4px 18px rgba(236, 72, 153, 0.3);
            transition: transform 0.2s, box-shadow 0.2s;
            margin-top: 0.5rem;
        }

        .btn-step-next:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(236, 72, 153, 0.42);
        }

        .btn-step-next:active { transform: scale(0.97); }

        .btn-step-back {
            padding: 0.95rem 1.4rem;
            background: transparent;
            color: #64748b;
            border: 2px solid #e2e8f0;
            border-radius: 0.85rem;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            transition: border-color 0.2s, color 0.2s;
            white-space: nowrap;
        }

        .btn-step-back:hover { border-color: #ec4899; color: #ec4899; }

        .btn-row { display: flex; gap: 0.75rem; margin-top: 0.5rem; }
        .btn-row .btn-step-next { flex: 1; margin-top: 0; }

        .btn-activate {
            flex: 1;
            padding: 0.95rem;
            background: linear-gradient(135deg, #9d174d, #ec4899, #a855f7);
            color: #fff;
            border: none;
            border-radius: 0.85rem;
            font-size: 1rem;
            font-weight: 800;
            cursor: pointer;
            letter-spacing: 0.04em;
            box-shadow: 0 4px 22px rgba(236, 72, 153, 0.38);
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .btn-activate:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 32px rgba(236, 72, 153, 0.52);
        }

        .btn-arrow { display: inline-block; transition: transform 0.2s; }
        .btn-step-next:hover .btn-arrow { transform: translateX(4px); }

        /* ==========================================
   17. REVIEW SUMMARY
   ========================================== */
        .review-list {
            background: #fdf2f8;
            border: 1px solid rgba(236, 72, 153, 0.14);
            border-radius: 1rem;
            padding: 1rem 1.25rem;
            margin: 1rem 0;
        }

        .review-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.5rem 0;
            border-bottom: 1px solid rgba(236, 72, 153, 0.08);
            font-size: 0.875rem;
            gap: 1rem;
        }

        .review-row:last-child { border-bottom: none; }
        .review-key { color: #64748b; font-weight: 500; }
        .review-val { color: #0f172a; font-weight: 700; word-break: break-all; }

        .login-link {
            text-align: center;
            margin-top: 1.25rem;
            font-size: 0.85rem;
            color: #64748b;
        }

        .login-link a { color: #ec4899; font-weight: 600; text-decoration: none; }
        .login-link a:hover { text-decoration: underline; }

        .inline-error {
            background: #fff1f2;
            border-left: 4px solid #ef4444;
            color: #b91c1c;
            padding: 0.75rem 1rem;
            border-radius: 0.5rem;
            font-size: 0.875rem;
            font-weight: 600;
            margin-bottom: 1.25rem;
        }

        /* ==========================================
   18. EMERGENCY CARD PREVIEW
   ========================================== */
        .register-preview-panel { position: sticky; top: 90px; }

        .preview-label {
            text-align: center;
            font-size: 0.72rem;
            font-weight: 700;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            margin-bottom: 1rem;
        }

        .ec-card {
            border-radius: 1.25rem;
            overflow: hidden;
            box-shadow: 0 25px 60px rgba(0, 0, 0, 0.1), 0 8px 24px rgba(236, 72, 153, 0.14);
            background: white;
            transform: perspective(900px) rotateY(-4deg) rotateX(2deg);
            transition: transform 0.4s ease;
        }

        .ec-card:hover {
            transform: perspective(900px) rotateY(0deg) rotateX(0deg);
        }

        .ec-card-header {
            background: linear-gradient(135deg, #9d174d 0%, #ec4899 60%, #f472b6 100%);
            padding: 1.1rem 1.4rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .ec-logo-text {
            font-size: 1.35rem;
            font-weight: 900;
            color: white;
            letter-spacing: 0.05em;
        }

        .ec-paw {
            display: inline-block;
            width: 1.05em;
            height: 1.05em;
            vertical-align: -0.15em;
        }

        .ec-badge {
            font-size: 0.6rem;
            font-weight: 800;
            color: rgba(255, 255, 255, 0.9);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            background: rgba(255, 255, 255, 0.2);
            padding: 0.22rem 0.6rem;
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, 0.3);
        }

        .ec-card-body {
            padding: 1.25rem 1.4rem;
            display: flex;
            gap: 1.25rem;
            align-items: flex-start;
        }

        .ec-qr-col {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.4rem;
            flex-shrink: 0;
        }

        .ec-qr-box {
            border: 2px solid #1e293b;
            border-radius: 4px;
            overflow: hidden;
            line-height: 0;
        }

        .qr-label {
            font-size: 0.6rem;
            color: #94a3b8;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            text-align: center;
        }

        .ec-info-col { flex: 1; min-width: 0; }
        .ec-cat-emoji { font-size: 1.75rem; margin-bottom: 0.2rem; }

        .ec-cat-name {
            font-size: 1rem;
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 0.5rem;
        }

        .ec-field {
            font-size: 0.78rem;
            color: #475569;
            margin-bottom: 0.25rem;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            transition: color 0.25s;
        }

        .ec-field.updated { color: #ec4899; }

        .ec-card-footer {
            background: #f8fafc;
            border-top: 1px solid #e2e8f0;
            padding: 0.65rem 1.4rem;
            font-size: 0.68rem;
            color: #94a3b8;
            font-weight: 600;
            text-align: center;
        }

        .preview-note {
            text-align: center;
            font-size: 0.73rem;
            color: #94a3b8;
            margin-top: 0.75rem;
        }

        /* ==========================================
   19. FLOATING BACKGROUND ELEMENTS
   ========================================== */
        .bg-floats {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }

        .float-el {
            position: absolute;
            opacity: 0.07;
            animation: gentleFloat 9s ease-in-out infinite;
            user-select: none;
        }

        @keyframes gentleFloat {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            33%       { transform: translateY(-18px) rotate(8deg); }
            66%       { transform: translateY(-8px) rotate(-6deg); }
        }

        .main-content { position: relative; z-index: 1; }

        /* ==========================================
   20. TOAST NOTIFICATIONS
   ========================================== */
        .toast {
            position: fixed;
            bottom: 1.5rem;
            left: 50%;
            transform: translateX(-50%) translateY(5rem);
            background: white;
            border-radius: 0.85rem;
            padding: 0.9rem 1.5rem;
            box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
            font-size: 0.9rem;
            font-weight: 600;
            color: #0f172a;
            z-index: 9999;
            border-left: 4px solid #ec4899;
            transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
            white-space: nowrap;
        }

        .toast.show { transform: translateX(-50%) translateY(0); }
        .toast.toast-error { border-left-color: #ef4444; color: #b91c1c; }

        /* ==========================================
   21. SUCCESS OVERLAY
   ========================================== */
        .success-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.82);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            z-index: 9998;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.4s ease;
        }

        .success-overlay.active { opacity: 1; pointer-events: all; }

        .success-box {
            background: white;
            border-radius: 2rem;
            padding: 3rem;
            text-align: center;
            position: relative;
            overflow: hidden;
            max-width: 420px;
            width: 90%;
            animation: popIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }

        @keyframes popIn {
            from { transform: scale(0.75); opacity: 0; }
            to   { transform: scale(1);    opacity: 1; }
        }

        .success-cat-emoji {
            font-size: 3.5rem;
            display: block;
            margin-bottom: 0.5rem;
            animation: bounceIn 0.6s ease 0.2s both;
        }

        @keyframes bounceIn {
            0%   { transform: translateY(-24px); opacity: 0; }
            60%  { transform: translateY(6px); }
            100% { transform: translateY(0); opacity: 1; }
        }

        .success-check {
            width: 3.5rem;
            height: 3.5rem;
            background: linear-gradient(135deg, #ec4899, #a855f7);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.6rem;
            font-weight: 900;
            margin: 0 auto 1.5rem;
            box-shadow: 0 0 28px rgba(236, 72, 153, 0.45);
        }

        .success-box h2 {
            font-size: 1.7rem;
            font-weight: 900;
            color: #0f172a;
            margin-bottom: 0.4rem;
        }

        .success-box p { color: #64748b; margin-bottom: 2rem; }

        .paw-confetti {
            position: absolute;
            inset: 0;
            pointer-events: none;
            overflow: hidden;
        }

        .confetti-paw {
            position: absolute;
            top: -2rem;
            animation: confettiFall linear forwards;
        }

        @keyframes confettiFall {
            to { transform: translateY(120%); opacity: 0; }
        }

        .btn-go-login {
            display: inline-block;
            background: linear-gradient(135deg, #ec4899, #a855f7);
            color: white;
            text-decoration: none;
            padding: 0.85rem 2rem;
            border-radius: 0.85rem;
            font-weight: 700;
            box-shadow: 0 4px 18px rgba(236, 72, 153, 0.32);
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .btn-go-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(236, 72, 153, 0.44);
        }

        /* ==========================================
   22. PAW CURSOR TRAIL
   ========================================== */
        .cursor-paw {
            position: fixed;
            width: 1.4rem;
            height: 1.4rem;
            pointer-events: none;
            z-index: 9997;
            animation: pawFade 0.85s ease forwards;
        }

        @keyframes pawFade {
            0%   { opacity: 0.6; transform: translate(-50%, -50%) scale(1); }
            100% { opacity: 0;   transform: translate(-50%, -50%) scale(0.4); }
        }

        /* ==========================================
   23. CAT BLINKING
   ========================================== */
        .cat-eye-blink {
            transform-box: fill-box;
            transform-origin: center;
        }

        .peeking-cat .cat-eye-blink {
            animation: catBlink 5s ease-in-out infinite;
        }

        .peeking-cat-top .cat-eye-blink {
            animation: catBlink 4.5s ease-in-out 1.2s infinite;
        }

        @keyframes catBlink {
            0%, 87%, 100% { transform: scaleY(1); }
            91%           { transform: scaleY(0.06); }
        }

        /* ==========================================
   24. EMERGENCY BUTTON PULSE — handled in section 8
   ========================================== */

        /* ==========================================
   10. PEEKING CAT DECORATION
   ========================================== */
        .peeking-cat {
            position: fixed;
            bottom: 0;
            right: 2.5rem;
            width: 160px;
            height: 119px;    /* clips at toe level so paws rest on screen edge */
            overflow: hidden;
            pointer-events: none;
            z-index: 500;
        }

        .peeking-cat svg {
            display: block;
            width: 160px;
        }


        /* Orange upside-down cat peeking from header */
        .peeking-cat-top {
            position: fixed;
            top: 47px;
            left: 2.5rem;
            width: 160px;
            height: 110px;
            overflow: hidden;
            pointer-events: none;
            z-index: 500;
        }

        .peeking-cat-top svg {
            display: block;
            width: 160px;
        }

    </style>
</head>

