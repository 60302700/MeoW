<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <style>
        /* ==========================================
   1. GLOBAL RESETS & FOUNDATION
   ========================================== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: #f1f5f9;
            font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            color: #0f172a;
            width: 100vw;
            min-height: 100vh;

            /* Standard top-to-bottom layout flow */
            display: flex;
            flex-direction: column;
        }

        /* Centering main wrapper area for form cards under the navbar */
        .main-content {
            flex: 1;
            /* Takes up all remaining screen space */
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        /* ==========================================
   2. REUSABLE UTILITY LAYOUT CLASSES
   ========================================== */
        .w-full {
            width: 100%;
        }

        .max-w-md {
            max-width: 28rem;
        }

        .hidden {
            display: none !important;
        }

        .block {
            display: block !important;
        }

        /* Text Alignment & Transformations */
        .text-center {
            text-align: center;
        }

        .text-left {
            text-align: left;
        }

        .text-right {
            text-align: right;
        }

        .uppercase {
            text-transform: uppercase;
        }

        /* Typography Scale */
        .title-xl {
            font-size: 1.875rem;
            font-weight: 900;
            color: #0f172a;
        }

        .title-lg {
            font-size: 1.25rem;
            font-weight: 700;
            color: #1e293b;
        }

        .text-sm {
            font-size: 0.875rem;
        }

        .text-xs {
            font-size: 0.75rem;
        }

        /* Spacing Components (Stacking items cleanly) */
        .space-y-4>*+* {
            margin-top: 1rem;
        }

        .mb-2 {
            margin-bottom: 0.5rem;
        }

        .mb-4 {
            margin-bottom: 1rem;
        }

        .mb-6 {
            margin-bottom: 1.5rem;
        }

        /* Color States */
        .text-slate-600 {
            color: #475569;
        }

        .text-red-600 {
            color: #dc2626;
        }

        /* ==========================================
   3. THE CONTAINER CARD ARCHITECTURE
   ========================================== */
        .card {
            background-color: #ffffff;
            border-radius: 1rem;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            overflow: hidden;
            border: 4px solid transparent;
            transition: all 500ms ease;
            width: 100%;
        }

        .card-body {
            padding: 1.5rem;
            /* Internal container layout padding */
        }

        /* ==========================================
   4. NAVIGATION & HEADERS
   ========================================== */
        .header-bar {
            padding: 1.25rem;
            color: #ffffff;
            font-weight: 700;
            letter-spacing: 0.05em;
            text-align: center;
            text-transform: uppercase;
            transition: background-color 500ms ease;
        }

        /* Header Variations */
        .bg-slate-dark {
            background-color: #1e293b;
        }

        .bg-emergency-red {
            background-color: #dc2626;
        }

        .header-bar a {
            color: #ffffff;
            text-decoration: none;
            font-size: 0.875rem;
            transition: opacity 0.2s;
        }

        .header-bar a:hover {
            opacity: 0.8;
        }

        /* ==========================================
   5. FORM FIELDS & INPUTS
   ========================================== */
        .form-group {
            display: flex;
            flex-direction: column;
            margin: 0;
        }

        .input-field {
            width: 100%;
            box-sizing: border-box;
            font-size: 1rem;
            padding: 0.75rem 1rem;
            border: 2px solid #cbd5e1;
            border-radius: 0.75rem;
            background-color: #ffffff;
            color: #0f172a;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .input-field:focus {
            outline: none;
            border-color: #0d9488;
            /* Calm teal color boundary on focus */
            box-shadow: 0 0 0 4px rgba(13, 148, 136, 0.1);
        }

        /* Special styling wrapper for numeric codes/tokens */
        .input-code {
            text-align: center;
            font-size: 1.5rem;
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, monospace;
            letter-spacing: 0.1em;
        }

        /* ==========================================
   6. ACTIONS & BUTTONS
   ========================================== */
        .btn {
            width: 100%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            padding: 1rem 1.5rem;
            border-radius: 0.75rem;
            border: none;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            transition: all 0.2s ease;
            color: #ffffff;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        .btn:active {
            transform: scale(0.98);
        }

        /* Button Variations */
        .btn-teal {
            background-color: #0d9488;
        }

        .btn-teal:hover {
            background-color: #0f766e;
        }

        .btn-red {
            background-color: #dc2626;
            font-weight: 900;
        }

        .btn-red:hover {
            background-color: #b91c1c;
        }

        .btn-orange {
            background-color: #ea580c;
        }

        .btn-orange:hover {
            background-color: #c2410c;
        }

        /* ==========================================
   7. STATUS CALLOUT BLOCKS & BANNERS
   ========================================== */
        .alert-box {
            padding: 1rem;
            border-radius: 0.75rem;
            margin-bottom: 1.5rem;
            font-size: 0.875rem;
        }

        .alert-warning {
            background-color: #fffbeb;
            border-left: 4px solid #d97706;
            color: #92400e;
        }

        .alert-info {
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
            color: #475569;
        }

        /* ==========================================
   8. SYSTEM ANIMATIONS
   ========================================== */
        @keyframes pulse-opacity {

            0%,
            100% {
                opacity: 1;
            }

            50% {
                opacity: .5;
            }
        }

        .animate-pulse {
            animation: pulse-opacity 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }

        @keyframes pulse-border {

            0%,
            100% {
                border-color: rgba(220, 38, 38, 1);
            }

            50% {
                border-color: rgba(220, 38, 38, 0.4);
            }
        }

        .emergency-pulse {
            animation: pulse-border 2s infinite;
        }

        /* Global Navigation Header Bar (Spans full window width) */
        .global-navbar {
            width: 100%;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            border-bottom: 2px solid #0d9488;
            padding: 0.85rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 4px 20px -2px rgba(13, 148, 136, 0.2);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        /* Brand Logo Layout Styles */
        .navbar-brand h3 {
            margin: 0;
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: 0.05em;
        }

        .navbar-brand h3 a {
            text-decoration: none;
            background: linear-gradient(to right, #38bdf8, #2dd4bf);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: transform 0.3s ease;
        }

        .navbar-brand h3 a:hover {
            transform: scale(1.05);
        }

        /* Navigation Links Container Alignment */
        .navbar-links ul {
            list-style: none;
            display: flex;
            align-items: center;
            gap: 1.5rem;
            margin: 0;
            padding: 0;
        }

        .navbar-links a {
            color: #94a3b8;
            text-decoration: none;
            font-size: 0.875rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            transition: color 0.3s ease;
            position: relative;
            padding: 0.25rem 0;
        }

        .navbar-links a:hover {
            color: #38bdf8;
        }

        /* Nav link hover slide underline effect */
        .navbar-links a::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: -2px;
            left: 0;
            background-color: #2dd4bf;
            transition: width 0.3s ease;
        }

        .navbar-links a:hover::after {
            width: 100%;
        }

        /* Special style for Emergency link to add dynamic alert coloring */
        .navbar-links a.nav-emergency {
            color: #f87171;
            padding: 0.4rem 0.85rem;
            border-radius: 0.5rem;
            border: 1px solid rgba(239, 68, 68, 0.4);
            background-color: rgba(239, 68, 68, 0.08);
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
        }

        .navbar-links a.nav-emergency::after {
            display: none;
        }

        .navbar-links a.nav-emergency:hover {
            color: #ffffff;
            background-color: #dc2626;
            border-color: #dc2626;
            box-shadow: 0 0 12px rgba(220, 38, 38, 0.4);
        }

        /* ==========================================
   9. EMERGENCY PORTAL COMPONENTS
   ========================================== */
        .flex {
            display: flex;
        }

        .items-center {
            align-items: center;
        }

        .justify-center {
            justify-content: center;
        }

        .space-x-4>*+* {
            margin-left: 1rem;
        }

        .avatar {
            width: 4rem;
            height: 4rem;
            border-radius: 9999px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.875rem;
        }

        .avatar-emergency {
            background-color: #fee2e2;
            border: 2px solid #ef4444;
        }
    </style>
</head>

<body>
    <header class="global-navbar">
        <div class="navbar-brand">
            <h3><a href="/">MeoW</a></h3>
        </div>
        <nav class="navbar-links">
            <ul>
                <li><a href="/register">Register</a></li>
                {{#if isLoggedIn}}
                <li><a href="/login">LogOut</a></li>
                {{/if}}
                {{#unless isLoggedIn}}
                <li><a href="/logout">Login</a></li>
                {{/unless}}
                <li><a href="/emergency" class="nav-emergency">🚨 Emergency</a></li>
            </ul>
        </nav>
    </header>
    <div class="main-content">
        {{{body}}}
    </div>
</body>

</html>