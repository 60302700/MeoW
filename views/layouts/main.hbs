<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <style>
        /* ==========================================
   1. GLOBAL RESETS & FOUNDATION
   ========================================== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: #f1f5f9;
            font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            color: #0f172a;
            width: 100vw;
            min-height: 100vh;

            /* Standard top-to-bottom layout flow */
            display: flex;
            flex-direction: column;
        }

        /* Centering main wrapper area for form cards under the navbar */
        .main-content {
            flex: 1;
            /* Takes up all remaining screen space */
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }

        /* ==========================================
   2. REUSABLE UTILITY LAYOUT CLASSES
   ========================================== */
        .w-full {
            width: 100%;
        }

        .max-w-md {
            max-width: 28rem;
        }

        .hidden {
            display: none !important;
        }

        .block {
            display: block !important;
        }

        /* Text Alignment & Transformations */
        .text-center {
            text-align: center;
        }

        .text-left {
            text-align: left;
        }

        .text-right {
            text-align: right;
        }

        .uppercase {
            text-transform: uppercase;
        }

        /* Typography Scale */
        .title-xl {
            font-size: 1.875rem;
            font-weight: 900;
            color: #0f172a;
        }

        .title-lg {
            font-size: 1.25rem;
            font-weight: 700;
            color: #1e293b;
        }

        .text-sm {
            font-size: 0.875rem;
        }

        .text-xs {
            font-size: 0.75rem;
        }

        /* Spacing Components (Stacking items cleanly) */
        .space-y-4>*+* {
            margin-top: 1rem;
        }

        .mb-2 {
            margin-bottom: 0.5rem;
        }

        .mb-4 {
            margin-bottom: 1rem;
        }

        .mb-6 {
            margin-bottom: 1.5rem;
        }

        /* Color States */
        .text-slate-600 {
            color: #475569;
        }

        .text-red-600 {
            color: #dc2626;
        }

        /* ==========================================
   3. THE CONTAINER CARD ARCHITECTURE
   ========================================== */
        .card {
            background-color: #ffffff;
            border-radius: 1rem;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            overflow: hidden;
            border: 4px solid transparent;
            transition: all 500ms ease;
            width: 100%;
        }

        .card-body {
            padding: 1.5rem;
            /* Internal container layout padding */
        }

        /* ==========================================
   4. NAVIGATION & HEADERS
   ========================================== */
        .header-bar {
            padding: 1.25rem;
            color: #ffffff;
            font-weight: 700;
            letter-spacing: 0.05em;
            text-align: center;
            text-transform: uppercase;
            transition: background-color 500ms ease;
        }

        /* Header Variations */
        .bg-slate-dark {
            background: linear-gradient(135deg, #9d174d 0%, #ec4899 60%, #f472b6 100%);
        }

        .bg-emergency-red {
            background-color: #dc2626;
        }

        .header-bar a {
            color: #ffffff;
            text-decoration: none;
            font-size: 0.875rem;
            transition: opacity 0.2s;
        }

        .header-bar a:hover {
            opacity: 0.8;
        }

        /* ==========================================
   5. FORM FIELDS & INPUTS
   ========================================== */
        .form-group {
            display: flex;
            flex-direction: column;
            margin: 0;
        }

        .input-field {
            width: 100%;
            box-sizing: border-box;
            font-size: 1rem;
            padding: 0.75rem 1rem;
            border: 2px solid #cbd5e1;
            border-radius: 0.75rem;
            background-color: #ffffff;
            color: #0f172a;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .input-field:focus {
            outline: none;
            border-color: #ec4899;
            /* Calm teal color boundary on focus */
            box-shadow: 0 0 0 4px rgba(236, 72, 153, 0.1);
        }

        /* Special styling wrapper for numeric codes/tokens */
        .input-code {
            text-align: center;
            font-size: 1.5rem;
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, monospace;
            letter-spacing: 0.1em;
        }

        /* ==========================================
   6. ACTIONS & BUTTONS
   ========================================== */
        .btn {
            width: 100%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            padding: 1rem 1.5rem;
            border-radius: 0.75rem;
            border: none;
            cursor: pointer;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            transition: all 0.2s ease;
            color: #ffffff;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }

        .btn:active {
            transform: scale(0.98);
        }

        /* Button Variations */
        .btn-teal {
            background-color: #ec4899;
        }

        .btn-teal:hover {
            background-color: #be185d;
        }

        .btn-red {
            background-color: #dc2626;
            font-weight: 900;
        }

        .btn-red:hover {
            background-color: #b91c1c;
        }

        .btn-orange {
            background-color: #ea580c;
        }

        .btn-orange:hover {
            background-color: #c2410c;
        }

        /* ==========================================
   7. STATUS CALLOUT BLOCKS & BANNERS
   ========================================== */
        .alert-box {
            padding: 1rem;
            border-radius: 0.75rem;
            margin-bottom: 1.5rem;
            font-size: 0.875rem;
        }

        .alert-warning {
            background-color: #fffbeb;
            border-left: 4px solid #d97706;
            color: #92400e;
        }

        .alert-info {
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
            color: #475569;
        }

        /* ==========================================
   8. SYSTEM ANIMATIONS
   ========================================== */
        @keyframes pulse-opacity {

            0%,
            100% {
                opacity: 1;
            }

            50% {
                opacity: .5;
            }
        }

        .animate-pulse {
            animation: pulse-opacity 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }

        @keyframes pulse-border {

            0%,
            100% {
                border-color: rgba(220, 38, 38, 1);
            }

            50% {
                border-color: rgba(220, 38, 38, 0.4);
            }
        }

        .emergency-pulse {
            animation: pulse-border 2s infinite;
        }

        /* Global Navigation Header Bar (Spans full window width) */
        .global-navbar {
            width: 100%;
            background: linear-gradient(135deg, #9d174d 0%, #ec4899 60%, #f472b6 100%);
            border-bottom: 2px solid #ec4899;
            padding: 0.85rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 4px 20px -2px rgba(236, 72, 153, 0.2);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        /* Brand Logo Layout Styles */
        .navbar-brand h3 {
            margin: 0;
            font-size: 1.5rem;
            font-weight: 800;
            letter-spacing: 0.05em;
        }

        .navbar-brand h3 a {
            text-decoration: none;
            background: linear-gradient(to right, #ffffff, #fce7f3);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            display: inline-block;
            transition: transform 0.3s ease;
        }

        .navbar-brand h3 a:hover {
            transform: scale(1.05);
        }

        /* Paw-print stand-in for the "o" in the MeoW logo */
        .logo-paw {
            display: inline-block;
            width: 0.85em;
            height: 0.85em;
            vertical-align: -0.1em;
        }

        /* Navigation Links Container Alignment */
        .navbar-links ul {
            list-style: none;
            display: flex;
            align-items: center;
            gap: 1.5rem;
            margin: 0;
            padding: 0;
        }

        .navbar-links a {
            color: #fce7f3;
            text-decoration: none;
            font-size: 0.875rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            transition: color 0.3s ease;
            position: relative;
            padding: 0.25rem 0;
        }

        .navbar-links a:hover {
            color: #ffffff;
        }

        /* Nav link hover slide underline effect */
        .navbar-links a::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: -2px;
            left: 0;
            background-color: #ec4899;
            transition: width 0.3s ease;
        }

        .navbar-links a:hover::after {
            width: 100%;
        }

        /* Special style for Emergency link to add dynamic alert coloring */
        .navbar-links a.nav-emergency {
            color: #f87171;
            padding: 0.4rem 0.85rem;
            border-radius: 0.5rem;
            border: 1px solid rgba(239, 68, 68, 0.4);
            background-color: rgba(239, 68, 68, 0.08);
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
        }

        .navbar-links a.nav-emergency::after {
            display: none;
        }

        .navbar-links a.nav-emergency:hover {
            color: #ffffff;
            background-color: #dc2626;
            border-color: #dc2626;
            box-shadow: 0 0 12px rgba(220, 38, 38, 0.4);
        }

        /* ==========================================
   9. EMERGENCY PORTAL COMPONENTS
   ========================================== */
        .flex {
            display: flex;
        }

        .items-center {
            align-items: center;
        }

        .justify-center {
            justify-content: center;
        }

        .space-x-4>*+* {
            margin-left: 1rem;
        }

        .avatar {
            width: 4rem;
            height: 4rem;
            border-radius: 9999px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.875rem;
        }

        .avatar-emergency {
            background-color: #fee2e2;
            border: 2px solid #ef4444;
        }

        /* ==========================================
   10. PEEKING CAT DECORATION
   ========================================== */
        .peeking-cat {
            position: fixed;
            bottom: 0;
            right: 2.5rem;
            width: 160px;
            height: 119px;    /* clips at toe level so paws rest on screen edge */
            overflow: hidden;
            pointer-events: none;
            z-index: 500;
        }

        .peeking-cat svg {
            display: block;
            width: 160px;
        }


        /* Orange upside-down cat peeking from header */
        .peeking-cat-top {
            position: fixed;
            top: 47px;
            left: 2.5rem;
            width: 160px;
            height: 110px;
            overflow: hidden;
            pointer-events: none;
            z-index: 500;
        }

        .peeking-cat-top svg {
            display: block;
            width: 160px;
        }

    </style>
</head>

<body>
    <header class="global-navbar">
        <div class="navbar-brand">
            <h3><a href="/">Me<svg class="logo-paw" viewBox="0 0 64 64" aria-hidden="true">
                        <defs>
                            <linearGradient id="pawGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#f472b6" />
                                <stop offset="50%" stop-color="#ec4899" />
                                <stop offset="100%" stop-color="#a855f7" />
                            </linearGradient>
                        </defs>
                        <g fill="url(#pawGradient)">
                            <ellipse cx="32" cy="42" rx="17" ry="14" />
                            <ellipse cx="13" cy="24" rx="8" ry="10" transform="rotate(-20 13 24)" />
                            <ellipse cx="26" cy="13" rx="8" ry="10" transform="rotate(-5 26 13)" />
                            <ellipse cx="41" cy="13" rx="8" ry="10" transform="rotate(8 41 13)" />
                            <ellipse cx="53" cy="25" rx="8" ry="10" transform="rotate(22 53 25)" />
                        </g>
                    </svg>W</a></h3>
        </div>
        <nav class="navbar-links">
            <ul>
                <li><a href="/register">Register</a></li>
                {{#if isLoggedIn}}
                <li><a href="/logout">LogOut</a></li>
                {{/if}}
                {{#unless isLoggedIn}}
                <li><a href="/login">Login</a></li>
                {{/unless}}
                <li><a href="/emergency" class="nav-emergency">🚨 Emergency</a></li>
            </ul>
        </nav>
    </header>
    <div class="main-content">
        {{{body}}}
    </div>

    <!-- Orange upside-down cat peeking from header -->
    <div class="peeking-cat-top" aria-hidden="true">
        <!--
            Flipped design: paws at top (y=11-28), head in middle (center y=38),
            ears pointing down (y=58-82). Container clips at 110px, hiding ear tips.
            Navbar z-index:1000 hides the cat when it floats up behind it.
        -->
        <svg viewBox="0 0 120 90" xmlns="http://www.w3.org/2000/svg">
            <!-- Left paw (gripping header bottom) -->
            <ellipse cx="14"  cy="18" rx="14" ry="10" fill="#ea580c"/>
            <ellipse cx="6"   cy="14" rx="5"  ry="4"  fill="#c2410c"/>
            <ellipse cx="14"  cy="11" rx="5"  ry="4"  fill="#c2410c"/>
            <ellipse cx="22"  cy="14" rx="5"  ry="4"  fill="#c2410c"/>
            <!-- Right paw -->
            <ellipse cx="106" cy="18" rx="14" ry="10" fill="#ea580c"/>
            <ellipse cx="98"  cy="14" rx="5"  ry="4"  fill="#c2410c"/>
            <ellipse cx="106" cy="11" rx="5"  ry="4"  fill="#c2410c"/>
            <ellipse cx="114" cy="14" rx="5"  ry="4"  fill="#c2410c"/>
            <!-- Head -->
            <ellipse cx="60" cy="38" rx="38" ry="34" fill="#ea580c"/>
            <!-- Left ear pointing down -->
            <polygon points="28,58 18,82 42,64" fill="#ea580c"/>
            <polygon points="30,60 22,78 40,64" fill="#fb923c"/>
            <!-- Right ear pointing down -->
            <polygon points="92,58 102,82 78,64" fill="#ea580c"/>
            <polygon points="90,60 98,78 80,64" fill="#fb923c"/>
            <!-- Left eye -->
            <circle cx="44" cy="38" r="11" fill="#f5c842"/>
            <circle cx="44" cy="38" r="6"  fill="#111"/>
            <circle cx="41" cy="35" r="2.5" fill="white"/>
            <!-- Right eye -->
            <circle cx="76" cy="38" r="11" fill="#f5c842"/>
            <circle cx="76" cy="38" r="6"  fill="#111"/>
            <circle cx="73" cy="35" r="2.5" fill="white"/>
            <!-- Nose -->
            <ellipse cx="60" cy="26" rx="4" ry="3" fill="#e8a0b0"/>
            <!-- Whiskers left -->
            <line x1="24" y1="29" x2="52" y2="26" stroke="#aaa" stroke-width="1"/>
            <line x1="22" y1="24" x2="52" y2="24" stroke="#aaa" stroke-width="1"/>
            <!-- Whiskers right -->
            <line x1="96" y1="29" x2="68" y2="26" stroke="#aaa" stroke-width="1"/>
            <line x1="98" y1="24" x2="68" y2="24" stroke="#aaa" stroke-width="1"/>
        </svg>
    </div>

    <!-- Peeking cat decoration -->
    <div class="peeking-cat" aria-hidden="true">
        <svg viewBox="0 0 120 130" xmlns="http://www.w3.org/2000/svg">
            <!-- Left paw -->
            <ellipse cx="14" cy="82" rx="14" ry="10" fill="#1a1a1a"/>
            <ellipse cx="6" cy="86" rx="5" ry="4" fill="#222"/>
            <ellipse cx="14" cy="89" rx="5" ry="4" fill="#222"/>
            <ellipse cx="22" cy="86" rx="5" ry="4" fill="#222"/>
            <!-- Right paw -->
            <ellipse cx="106" cy="82" rx="14" ry="10" fill="#1a1a1a"/>
            <ellipse cx="98" cy="86" rx="5" ry="4" fill="#222"/>
            <ellipse cx="106" cy="89" rx="5" ry="4" fill="#222"/>
            <ellipse cx="114" cy="86" rx="5" ry="4" fill="#222"/>
            <!-- Head -->
            <ellipse cx="60" cy="62" rx="38" ry="34" fill="#1a1a1a"/>
            <!-- Left ear -->
            <polygon points="28,42 18,18 42,36" fill="#1a1a1a"/>
            <polygon points="30,40 22,22 40,36" fill="#2d2d2d"/>
            <!-- Right ear -->
            <polygon points="92,42 102,18 78,36" fill="#1a1a1a"/>
            <polygon points="90,40 98,22 80,36" fill="#2d2d2d"/>
            <!-- Left eye -->
            <circle cx="44" cy="62" r="11" fill="#f5c842"/>
            <circle cx="44" cy="62" r="6" fill="#111"/>
            <circle cx="41" cy="59" r="2.5" fill="white"/>
            <!-- Right eye -->
            <circle cx="76" cy="62" r="11" fill="#f5c842"/>
            <circle cx="76" cy="62" r="6" fill="#111"/>
            <circle cx="73" cy="59" r="2.5" fill="white"/>
            <!-- Nose -->
            <ellipse cx="60" cy="74" rx="4" ry="3" fill="#e8a0b0"/>
            <!-- Whiskers left -->
            <line x1="24" y1="71" x2="52" y2="74" stroke="#888" stroke-width="1"/>
            <line x1="22" y1="76" x2="52" y2="76" stroke="#888" stroke-width="1"/>
            <!-- Whiskers right -->
            <line x1="96" y1="71" x2="68" y2="74" stroke="#888" stroke-width="1"/>
            <line x1="98" y1="76" x2="68" y2="76" stroke="#888" stroke-width="1"/>
            <!-- Body -->
            <ellipse cx="60" cy="118" rx="32" ry="22" fill="#1a1a1a"/>
        </svg>
    </div>
</body>

</html>