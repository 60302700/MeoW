                        <defs>
                            <linearGradient id="pawGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#f472b6" />
                                <stop offset="50%" stop-color="#ec4899" />
                                <stop offset="100%" stop-color="#a855f7" />
                            </linearGradient>
                        </defs>
                        <g fill="url(#pawGradient)">
                            <ellipse cx="32" cy="42" rx="17" ry="14" />
                            <ellipse cx="13" cy="24" rx="8" ry="10" transform="rotate(-20 13 24)" />
                            <ellipse cx="26" cy="13" rx="8" ry="10" transform="rotate(-5 26 13)" />
                            <ellipse cx="41" cy="13" rx="8" ry="10" transform="rotate(8 41 13)" />
                            <ellipse cx="53" cy="25" rx="8" ry="10" transform="rotate(22 53 25)" />
                        </g>
                    </svg>W</a></h3>
        </div>
        <nav class="navbar-links">
            <ul>
                {{#unless isLoggedIn}}
                <li><a href="/register">Register</a></li>
                <li><a href="/login">Login</a></li>
                {{/unless}}
                {{#if user}}
                <li style="list-style:none;">
                    {{#if isUnavailable}}
                    <form method="POST" action="/owner/available" style="margin:0;">
                        <input type="hidden" name="_csrf" value="{{csrfToken}}">
                        <button type="submit" class="nav-emergency"
                            onclick="return confirm('Mark yourself as available? This will stop the guardian alert chain.')">
                            🚨 Cancel Alert
                        </button>
                    </form>
                    {{else}}
                    <form method="POST" action="/owner/unavailable" style="margin:0;">
                        <input type="hidden" name="_csrf" value="{{csrfToken}}">
                        <button type="submit" class="nav-emergency"
                            onclick="return confirm('This will send emergency alerts to your guardians in priority order. Continue?')">
                            🚨 Alert Guardians
                        </button>
                    </form>
                    {{/if}}
                </li>
                {{/if}}
                {{#if user}}
                <li style="list-style:none;">
                    <div class="profile-menu-wrap" id="profileMenuWrap">
                        <button class="profile-nav-btn" id="profileMenuBtn">
                            {{#if user.photoUrl}}
                            <img src="{{user.photoUrl}}" class="profile-nav-avatar" alt="Profile">
                            {{else}}
                            <span class="profile-nav-initials">{{initial user.name}}</span>
                            {{/if}}
                        </button>
                        <div class="profile-dropdown" id="profileDropdown">
                            <div class="dropdown-header">
                                <div class="dropdown-header-name">{{user.name}}</div>
                                <div class="dropdown-header-email">{{user.email}}</div>
                            </div>
                            <div class="dropdown-divider"></div>
                            <button class="dropdown-item" id="dropdownEditProfile">Edit Profile</button>
                            <button class="dropdown-item" id="dropdownChangePassword">Change Password</button>
                            <div class="dropdown-divider"></div>
                            <button class="dropdown-item dropdown-item-danger" id="dropdownLogout">Logout</button>
                        </div>
                    </div>
                </li>
                {{/if}}
            </ul>
        </nav>
    </header>
    {{{body}}}

    <script nonce="{{nonce}}">
        function closeProfileMenu() {
            const wrap = document.getElementById('profileMenuWrap');
            if (wrap) wrap.classList.remove('open');
        }

        (function () {
            const btn = document.getElementById('profileMenuBtn');
            if (btn) {
                btn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    const wrap = document.getElementById('profileMenuWrap');
                    if (wrap) wrap.classList.toggle('open');
                });
            }

            const ep = document.getElementById('dropdownEditProfile');
            if (ep) ep.addEventListener('click', function () { openEditProfile(); closeProfileMenu(); });

            const cp = document.getElementById('dropdownChangePassword');
            if (cp) cp.addEventListener('click', function () { openChangePassword(); closeProfileMenu(); });

            const lo = document.getElementById('dropdownLogout');
            if (lo) lo.addEventListener('click', function () { window.location = '/logout'; });

            document.addEventListener('click', function (e) {
                const wrap = document.getElementById('profileMenuWrap');
                if (wrap && !wrap.contains(e.target)) wrap.classList.remove('open');
            });
        })();
    </script>

</body>

</html>