<div class="main-content">
  <div class="w-full max-w-2xl bg-white rounded-3xl shadow-xl p-8">
    <div class="space-y-6">
      <div>
        <h1 class="title-xl">Edit Guardian</h1>
        <p class="text-slate-600 mt-2">Update guardian details. Changes will be
          saved to your account's guardian list.</p>
      </div>

      {{#if error}}
        <div
          class="rounded-xl bg-red-50 border border-red-200 p-4 text-red-700"
        >
          {{error}}
        </div>
      {{/if}}

      <form
        method="POST"
        action="/guardians/edit/{{guardian.Id}}"
        enctype="multipart/form-data"
        class="space-y-6 ge-form"
      >
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <style>
          .ge-form { font-family: Inter, system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial; }
          .ge-card-header { display:flex;align-items:center;gap:12px;padding:14px;border-radius:12px;background:linear-gradient(90deg,#fff7fb, #fff);box-shadow:0 6px 20px rgba(15,23,42,0.06);margin-bottom:6px }
          .ge-card-header .icon { font-size:22px; width:46px; height:46px; display:flex;align-items:center;justify-content:center;border-radius:10px;background:linear-gradient(180deg,#ec4899,#be185d);color:white;box-shadow:0 6px 18px rgba(236,72,153,0.18)}
          .ge-hint { color:#64748b;font-size:0.92rem;margin-top:2px }
          .ge-label { display:block;font-weight:700;color:#0f172a;font-size:0.85rem;margin-bottom:6px }
          .ge-input, .ge-select { width:100%; padding:12px 14px;border-radius:12px;border:1px solid #e6e9ef;background:white;box-shadow:inset 0 1px 0 rgba(16,24,40,0.02);transition:box-shadow .18s ease, transform .12s ease, border-color .12s ease }
          .ge-input:focus, .ge-select:focus { outline:none;border-color:#f9c2dd;box-shadow:0 8px 30px rgba(236,72,153,0.10);transform:translateY(-1px) }
          .ge-grid { display:grid;grid-template-columns:1fr;gap:14px }
          @media(min-width:720px){ .ge-grid{grid-template-columns:repeat(2,1fr)} }
          .ge-row { display:flex;gap:12px;align-items:center }
          .btn-primary { background:linear-gradient(90deg,#ec4899,#be185d);color:white;padding:10px 14px;border-radius:12px;border:none;font-weight:700;box-shadow:0 8px 20px rgba(236,72,153,0.15);transition:transform .12s ease,box-shadow .12s }
          .btn-primary:hover { transform:translateY(-2px); box-shadow:0 16px 36px rgba(236,72,153,0.18) }
          .btn-ghost { background:transparent;border:1px solid #e6e8ee;padding:10px 12px;border-radius:12px }
        </style>

        <div class="ge-card-header">
          {{#if guardian.photoUrl}}
          <img src="{{guardian.photoUrl}}" alt="{{guardian.name}}" style="width:46px;height:46px;border-radius:10px;object-fit:cover;box-shadow:0 6px 18px rgba(236,72,153,0.18);flex-shrink:0;">
          {{else}}
          <div class="icon">🛡️</div>
          {{/if}}
          <div>
            <div style="font-weight:800;color:#0f172a">Guardian Details</div>
            <div class="ge-hint">Edit contact info and response priority for this guardian.</div>
          </div>
        </div>

        <div>
          <label class="ge-label">Photo</label>
          <input type="file" name="photo" accept="image/*" class="ge-input" style="padding:10px 12px;" />
        </div>

        <div class="ge-grid">
          <div>
            <label class="ge-label">Full Name</label>
            <input name="name" value="{{guardian.name}}" required class="ge-input" />
          </div>

          <div>
            <label class="ge-label">Email</label>
            <input type="email" name="email" value="{{guardian.email}}" class="ge-input" />
          </div>

          <div>
            <label class="ge-label">Phone</label>
            <input type="tel" name="phone" value="{{guardian.phone}}" class="ge-input" />
          </div>

          <div>
            <label class="ge-label">Priority Order</label>
            <select id="g-priority-edit" name="priorityOrder" required class="ge-select">
              <option value="1" {{#if (eq guardian.priorityOrder 1)}}selected{{/if}}>Priority #1 (Immediate responder)</option>
              <option value="2" {{#if (eq guardian.priorityOrder 2)}}selected{{/if}}>Priority #2 (Backup responder)</option>
              <option value="3" {{#if (eq guardian.priorityOrder 3)}}selected{{/if}}>Priority #3</option>
              <option value="4" {{#if (eq guardian.priorityOrder 4)}}selected{{/if}}>Priority #4</option>
            </select>
          </div>
        </div>

        <div class="flex flex-wrap gap-3 items-center justify-between">
          <button type="submit" class="btn-primary">Save changes</button>
          <a href="/homepage" class="btn-ghost">Back to dashboard</a>
        </div>
      </form>
    </div>
  </div>
</div>