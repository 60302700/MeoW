<style>
    .scan-wrap {
        width: 100%;
        max-width: 480px;
        padding: 1rem;
    }

    .scan-card {
        background: white;
        border-radius: 1.5rem;
        box-shadow: 0 8px 40px rgba(0,0,0,0.10);
        overflow: hidden;
    }

    .scan-header {
        background: linear-gradient(135deg, #9d174d, #ec4899);
        padding: 1.5rem 1.75rem 1.25rem;
    }

    .scan-header-label {
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.65);
        margin: 0 0 0.3rem;
    }

    .scan-header h1 {
        margin: 0;
        color: white;
        font-size: 1.35rem;
        font-weight: 800;
    }

    .scan-body {
        padding: 1.5rem 1.75rem;
    }

    .scan-error {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        background: #fef2f2;
        border: 1px solid #fecaca;
        color: #991b1b;
        padding: 0.75rem 1rem;
        border-radius: 0.75rem;
        font-size: 0.85rem;
        font-weight: 600;
        margin-bottom: 1.25rem;
    }

    .scan-input {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        font-size: 0.95rem;
        color: #0f172a;
        outline: none;
        box-sizing: border-box;
        transition: border-color 0.2s;
        background: #f8fafc;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        letter-spacing: 0.05em;
    }

    .scan-input:focus { border-color: #ec4899; background: white; }

    .scan-btn {
        width: 100%;
        padding: 0.85rem;
        background: linear-gradient(135deg, #9d174d, #ec4899);
        color: white;
        border: none;
        border-radius: 0.75rem;
        font-size: 0.95rem;
        font-weight: 700;
        cursor: pointer;
        transition: opacity 0.15s;
        margin-top: 0.85rem;
    }

    .scan-btn:hover { opacity: 0.92; }
    .scan-btn:disabled { opacity: 0.6; cursor: not-allowed; }

    .scan-btn-outline {
        width: 100%;
        padding: 0.75rem;
        background: none;
        color: #64748b;
        border: 2px solid #e2e8f0;
        border-radius: 0.75rem;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: border-color 0.2s;
        margin-top: 0.6rem;
    }

    .scan-btn-outline:hover { border-color: #ec4899; color: #ec4899; }

    /* Cat info banner */
    .cat-banner {
        display: flex;
        align-items: center;
        gap: 1rem;
        background: #fdf2f8;
        border: 1px solid #fbcfe8;
        border-radius: 1rem;
        padding: 1rem 1.1rem;
        margin-bottom: 1.25rem;
    }

    .cat-banner-photo {
        width: 56px;
        height: 56px;
        border-radius: 0.65rem;
        object-fit: cover;
        flex-shrink: 0;
        border: 1px solid #fbcfe8;
    }

    .cat-banner-placeholder {
        width: 56px;
        height: 56px;
        border-radius: 0.65rem;
        background: linear-gradient(135deg, #fce7f3, #f5f3ff);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 1.6rem;
    }

    .cat-banner-name {
        font-size: 1.1rem;
        font-weight: 800;
        color: #0f172a;
        margin: 0 0 0.15rem;
    }

    .cat-banner-meta {
        font-size: 0.78rem;
        color: #64748b;
        margin: 0;
    }

    /* Owner info card */
    .owner-card {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 0.85rem;
        padding: 1rem 1.1rem;
        margin-bottom: 1.25rem;
    }

    .owner-card-label {
        font-size: 0.68rem;
        font-weight: 700;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin: 0 0 0.5rem;
    }

    .owner-card-name {
        font-size: 0.95rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0 0 0.25rem;
    }

    .owner-contact-row {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.82rem;
        color: #475569;
        margin-top: 0.2rem;
    }

    .owner-contact-row a {
        color: #ec4899;
        text-decoration: none;
        font-weight: 600;
    }

    .owner-contact-row a:hover { text-decoration: underline; }

    /* Divider */
    .scan-divider {
        border: none;
        border-top: 1px solid #f1f5f9;
        margin: 1.25rem 0;
    }

    /* Form field label */
    .field-label {
        display: block;
        font-size: 0.75rem;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: 0.3rem;
    }

    .field-wrap { margin-bottom: 0.85rem; }

    .field-required {
        color: #ec4899;
        margin-left: 2px;
    }

    /* Status badge */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.3rem 0.75rem;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 700;
    }

    .status-alerted {
        background: #fff7ed;
        color: #c2410c;
        border: 1px solid #fed7aa;
    }

    .status-responded {
        background: #f0fdf4;
        color: #166534;
        border: 1px solid #bbf7d0;
    }

    .status-owner-acked {
        background: #fdf2f8;
        color: #be185d;
        border: 1px solid #fbcfe8;
    }

    /* Escalation log */
    .escalation-log {
        margin-top: 1rem;
    }

    .escalation-log-title {
        font-size: 0.7rem;
        font-weight: 700;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        margin: 0 0 0.6rem;
    }

    .log-item {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.5rem 0;
        border-bottom: 1px solid #f1f5f9;
        font-size: 0.82rem;
        color: #475569;
    }

    .log-item:last-child { border-bottom: none; }

    .log-num {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: #f1f5f9;
        color: #64748b;
        font-size: 0.68rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    /* Success state */
    .scan-success-icon {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: linear-gradient(135deg, #ec4899, #a855f7);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem;
    }

    @media (max-width: 480px) {
        .scan-body { padding: 1.25rem; }
        .scan-header { padding: 1.25rem 1.25rem 1rem; }
    }
</style>

<div class="scan-wrap">
<div class="scan-card">

{{!-- ── State 1: Owner acknowledged via email link ─────────────────────── --}}
{{#if ownerAckSuccess}}
<div class="scan-header">
    <p class="scan-header-label">MeoW Safety Gateway</p>
    <h1>Got it, thank you</h1>
</div>
<div class="scan-body" style="text-align:center;padding-top:2rem;padding-bottom:2rem;">
    <div class="scan-success-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
    </div>
    <p style="font-size:1rem;font-weight:800;color:#0f172a;margin:0 0 0.5rem;">Acknowledged</p>
    <p style="font-size:0.85rem;color:#64748b;line-height:1.6;margin:0;">We have stopped the guardian alert chain. Please contact the finder directly to arrange care for your cat.</p>
</div>

{{!-- ── State 2: Event status page (after alert sent) ─────────────────── --}}
{{else if emergency}}
<div class="scan-header">
    <p class="scan-header-label">MeoW Safety Gateway</p>
    <h1>{{#if claimed}}Guardian Responding{{else}}Alert Sent{{/if}}</h1>
</div>
<div class="scan-body">

    {{!-- Cat banner --}}
    <div class="cat-banner">
        {{#if cat.photoUrl}}
        <img src="{{cat.photoUrl}}" class="cat-banner-photo" alt="{{cat.name}}">
        {{else}}
        <div class="cat-banner-placeholder">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#ec4899" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="3.5" r="1.5"/><circle cx="15" cy="3.5" r="1.5"/><circle cx="4.5" cy="8.5" r="1.5"/><circle cx="19.5" cy="8.5" r="1.5"/><path d="M9 12c-2.5 0-5 2-5 6 0 2.5 2 3 4 3 1.5 0 3-0.5 4-0.5s2.5 0.5 4 0.5c2 0 4-0.5 4-3 0-4-2.5-6-5-6-1.5 0-2.5 0.5-3 0.5S10.5 12 9 12z"/></svg>
        </div>
        {{/if}}
        <div>
            <p class="cat-banner-name">{{cat.name}}</p>
            <p class="cat-banner-meta">{{#if cat.breed}}{{cat.breed}}{{/if}}{{#if cat.ageDisplay}} · {{cat.ageDisplay}}{{/if}}</p>
        </div>
    </div>

    {{!-- Status --}}
    <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;flex-wrap:wrap;">
        {{#if claimed}}
        <span class="status-badge status-responded">Guardian responding</span>
        {{else if ownerAcked}}
        <span class="status-badge status-owner-acked">Owner aware</span>
        {{else}}
        <span class="status-badge status-alerted">Waiting for response</span>
        {{/if}}
    </div>

    {{!-- What happens next --}}
    {{#unless claimed}}
    <div style="background:#fffbeb;border:1px solid #fde68a;border-radius:0.75rem;padding:0.85rem 1rem;margin-bottom:1.25rem;font-size:0.82rem;color:#92400e;line-height:1.6;">
        {{#if ownerAcked}}
        The owner has been notified and is aware. They will contact you directly.
        {{else}}
        The owner has been alerted by email. If they don't respond within 10 minutes, their guardians will be contacted automatically in priority order.
        {{/if}}
    </div>
    {{/unless}}

    {{!-- Finder info (confirmation for the finder) --}}
    {{#if event.finderName}}
    <div class="owner-card" style="margin-bottom:1.25rem;">
        <p class="owner-card-label">Your submitted info</p>
        <p class="owner-card-name">{{event.finderName}}</p>
        {{#if event.finderPhone}}<p class="owner-contact-row">{{event.finderPhone}}</p>{{/if}}
        {{#if event.finderLocation}}<p class="owner-contact-row">Found near: {{event.finderLocation}}</p>{{/if}}
        {{#if event.finderNotes}}<p class="owner-contact-row" style="margin-top:0.35rem;">{{event.finderNotes}}</p>{{/if}}
    </div>
    {{/if}}

    {{!-- Owner contact (so finder can call them) --}}
    {{#if owner}}
    <div class="owner-card">
        <p class="owner-card-label">Owner contact</p>
        <p class="owner-card-name">{{owner.name}}</p>
        {{#if owner.phone}}
        <div class="owner-contact-row">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <a href="tel:{{owner.phone}}">{{owner.phone}}</a>
        </div>
        {{/if}}
        <div class="owner-contact-row">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <a href="mailto:{{owner.email}}">{{owner.email}}</a>
        </div>
    </div>
    {{/if}}

    {{!-- Guardian claim --}}
    {{#unless claimed}}
    <hr class="scan-divider">
    <p style="font-size:0.8rem;color:#64748b;margin:0 0 0.75rem;line-height:1.5;">Are you one of the registered guardians? Claim this event to let others know you are handling it.</p>
    <form method="POST" action="/scan/{{event._id}}/claim">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <select name="guardianId" style="width:100%;padding:0.65rem 0.85rem;border:2px solid #e2e8f0;border-radius:0.75rem;font-size:0.9rem;color:#0f172a;outline:none;box-sizing:border-box;margin-bottom:0.6rem;background:white;">
            <option value="" disabled selected>Select your name</option>
            {{#each guardians}}
            <option value="{{this._id}}">{{this.name}}</option>
            {{/each}}
        </select>
        <button type="submit" class="scan-btn">I am on my way</button>
    </form>
    {{else}}
    <div style="text-align:center;padding:0.75rem 0;">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <p style="margin:0.5rem 0 0;font-size:0.85rem;font-weight:700;color:#166534;">A guardian is responding to this alert.</p>
    </div>
    {{/unless}}

    {{!-- Escalation log --}}
    {{#if event.escalationLog.length}}
    <div class="escalation-log">
        <p class="escalation-log-title">Escalation history</p>
        {{#each event.escalationLog}}
        <div class="log-item">
            <div class="log-num">{{this.priority}}</div>
            <span>{{this.guardianName}} notified</span>
        </div>
        {{/each}}
    </div>
    {{/if}}

</div>

{{!-- ── State 3: Cat found — show owner contact + finder form ─────────── --}}
{{else if catLookup}}
<div class="scan-header">
    <p class="scan-header-label">MeoW Safety Gateway</p>
    <h1>Cat Found</h1>
</div>
<div class="scan-body">

    {{#if lookupError}}
    <div class="scan-error">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        {{lookupError}}
    </div>
    {{/if}}

    {{!-- Cat info --}}
    <div class="cat-banner">
        {{#if cat.photoUrl}}
        <img src="{{cat.photoUrl}}" class="cat-banner-photo" alt="{{cat.name}}">
        {{else}}
        <div class="cat-banner-placeholder">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#ec4899" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="3.5" r="1.5"/><circle cx="15" cy="3.5" r="1.5"/><circle cx="4.5" cy="8.5" r="1.5"/><circle cx="19.5" cy="8.5" r="1.5"/><path d="M9 12c-2.5 0-5 2-5 6 0 2.5 2 3 4 3 1.5 0 3-0.5 4-0.5s2.5 0.5 4 0.5c2 0 4-0.5 4-3 0-4-2.5-6-5-6-1.5 0-2.5 0.5-3 0.5S10.5 12 9 12z"/></svg>
        </div>
        {{/if}}
        <div>
            <p class="cat-banner-name">{{cat.name}}</p>
            <p class="cat-banner-meta">{{#if cat.breed}}{{cat.breed}}{{/if}}{{#if cat.ageDisplay}} · {{cat.ageDisplay}}{{/if}}</p>
        </div>
    </div>

    {{!-- Owner contact --}}
    {{#if owner}}
    <div class="owner-card">
        <p class="owner-card-label">Owner contact</p>
        <p class="owner-card-name">{{owner.name}}</p>
        {{#if owner.phone}}
        <div class="owner-contact-row">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <a href="tel:{{owner.phone}}">{{owner.phone}}</a>
        </div>
        {{/if}}
        <div class="owner-contact-row">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <a href="mailto:{{owner.email}}">{{owner.email}}</a>
        </div>
    </div>
    {{/if}}

    <hr class="scan-divider">

    <p style="font-size:0.82rem;color:#475569;line-height:1.6;margin:0 0 1.1rem;">
        Please leave your details below so the owner can contact you. We will also alert them automatically — if they don't respond in 10 minutes their guardians will be notified.
    </p>

    <form method="POST" action="/scan">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <input type="hidden" name="qrCodeId" value="{{qrCodeId}}">

        <div class="field-wrap">
            <label class="field-label">Your Name <span class="field-required">*</span></label>
            <input type="text" name="finderName" class="scan-input" placeholder="e.g. Ali Hassan" required maxlength="100" autocomplete="name">
        </div>

        <div class="field-wrap">
            <label class="field-label">Your Phone Number <span class="field-required">*</span></label>
            <input type="tel" name="finderPhone" class="scan-input" placeholder="e.g. +974 5555 1234" required maxlength="30" autocomplete="tel">
        </div>

        <div class="field-wrap">
            <label class="field-label">Where did you find the cat?</label>
            <input type="text" name="finderLocation" class="scan-input" placeholder="e.g. Near City Center Mall, Doha" maxlength="200">
        </div>

        <div class="field-wrap">
            <label class="field-label">Additional notes</label>
            <textarea name="finderNotes" class="scan-input" style="font-family:inherit;min-height:72px;resize:vertical;letter-spacing:0;" placeholder="e.g. Cat seems healthy, found in a garden" maxlength="500"></textarea>
        </div>

        <button type="submit" class="scan-btn">Send alert to owner</button>
    </form>

</div>

{{!-- ── State 4: Default — enter QR code manually ──────────────────────── --}}
{{else}}
<div class="scan-header">
    <p class="scan-header-label">MeoW Safety Gateway</p>
    <h1>Found a cat?</h1>
</div>
<div class="scan-body">

    {{#if error}}
    <div class="scan-error">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        {{error}}
    </div>
    {{/if}}

    <p style="font-size:0.88rem;color:#475569;line-height:1.65;margin:0 0 1.25rem;">
        If you found a cat wearing a MeoW tag, enter the ID printed on the tag below. The owner will be alerted immediately.
    </p>

    <form method="GET" action="/scan">
        <label class="field-label">QR Code ID</label>
        <input type="text" name="qr" class="scan-input" placeholder="e.g. a1b2c3d4-..." required maxlength="64" style="margin-bottom:0;">
        <button type="submit" class="scan-btn">Look up cat</button>
    </form>

</div>
{{/if}}

</div>
</div>