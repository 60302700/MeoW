<div class="card max-w-md {{#if emergency}}emergency-pulse{{/if}}">
    <div class="header-bar {{#if emergency}}bg-emergency-red{{else}}bg-slate-dark{{/if}}">
        {{#if emergency}}🚨 Emergency Care Dispatch{{else}}MeoW Safety Gateway{{/if}}
    </div>

    <div class="card-body">
        {{#unless emergency}}
        <div class="text-center mb-6">
            <p class="text-sm text-slate-600 mb-2">First Responder / Dispatcher Portal</p>
            <h2 class="title-lg">Enter Emergency ID From Card</h2>
        </div>

        <form method="POST" action="/scan" class="space-y-4">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <input type="text" name="qrCodeId" placeholder="e.g., QR-WHISK-9921" class="input-field input-code"
                required>
            <button type="submit" class="btn btn-teal">Verify ID &amp; Alert Guardians</button>
        </form>

        {{#if error}}
        <p class="alert-box alert-warning text-center">❌ {{error}}</p>
        {{/if}}
        {{/unless}}

        {{#if emergency}}
        <div class="flex items-center space-x-4 mb-6">
            {{#if cat.photoUrl}}
            <img src="{{cat.photoUrl}}" class="avatar avatar-emergency" style="object-fit: cover;" alt="{{cat.name}}">
            {{else}}
            <div class="avatar avatar-emergency">🐈</div>
            {{/if}}
            <div>
                <h2 class="title-xl">{{cat.name}}</h2>
                <p class="text-xs text-red-600 uppercase animate-pulse">🚨 Animal Home Alone</p>
            </div>
        </div>

        <div class="alert-box alert-warning mb-6">
            <h3 class="text-xs uppercase mb-2">⚠️ Urgent Care Instructions</h3>
            {{#if cat.careInstructions.allergies}}
            <p class="text-sm mb-2">⚠️ Allergies: {{cat.careInstructions.allergies}}</p>
            {{/if}}
            {{#if cat.careInstructions.conditions}}
            <p class="text-sm mb-2">🩺 Conditions: {{cat.careInstructions.conditions}}</p>
            {{/if}}
            {{#if cat.careInstructions.medications}}
            <p class="text-sm mb-2">💊 Medications: {{cat.careInstructions.medications}}</p>
            {{/if}}
            {{#if cat.careInstructions.feedingSchedule}}
            <p class="text-sm">🍽️ Feeding: {{cat.careInstructions.feedingSchedule}}</p>
            {{/if}}
        </div>

        <div class="alert-box alert-info mb-6 space-y-2">
            <p><strong>Owner:</strong> Contact unavailable (Incapacitated)</p>
            {{#if cat.careInstructions.vetName}}
            <p>🏥 Vet: {{cat.careInstructions.vetName}}{{#if cat.careInstructions.vetPhone}} — {{cat.careInstructions.vetPhone}}{{/if}}</p>
            {{else}}
            <p>🏥 Vet: Not on file</p>
            {{/if}}
            <p><strong>Status:</strong> {{#if claimed}}Guardian responding{{else}}Automated Guardian Alerts
                Dispatched{{/if}}</p>
        </div>

        {{#if claimed}}
        <button class="btn btn-orange" disabled>✅ Guardian Responding (En Route)</button>
        {{else}}
        <form method="POST" action="/scan/{{event._id}}/claim" class="space-y-4">
            <input type="hidden" name="_csrf" value="{{csrfToken}}">
            <select name="guardianId" class="input-field" required>
                <option value="" disabled selected>Select your name</option>
                {{#each guardians}}
                <option value="{{this._id}}">{{this.name}}</option>
                {{/each}}
            </select>
            <button type="submit" class="btn btn-red">🙋‍♂️ I am on my way</button>
        </form>
        {{/if}}
        {{/if}}
    </div>
</div>