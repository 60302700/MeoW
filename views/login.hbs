<div class="glass-card max-w-md" style="width:100%;max-width:420px;">
    <div class="header-bar bg-slate-dark" style="border-radius:1rem 1rem 0 0;margin:-2rem -2rem 2rem;">
        Login
    </div>

    {{#if expired}}
    <div style="background:#fff7ed;border-left:4px solid #f97316;color:#9a3412;padding:0.75rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:600;margin-bottom:1.25rem;">
        ⏱️ Your session expired. Please sign in again.
    </div>
    {{/if}}

    {{#if reset}}
    <div style="background:#f0fdf4;border-left:4px solid #22c55e;color:#166534;padding:0.75rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:600;margin-bottom:1.25rem;">
        ✅ Password updated! Sign in with your new password.
    </div>
    {{/if}}

    {{#if deleted}}
    <div style="background:#f0fdf4;border-left:4px solid #22c55e;color:#166534;padding:0.75rem 1rem;border-radius:0.5rem;font-size:0.875rem;font-weight:600;margin-bottom:1.25rem;">
        Your account has been permanently deleted.
    </div>
    {{/if}}

    {{#if error}}
        <div class="inline-error">{{error}}</div>
    {{/if}}

    <form method="POST" action="/login">
        <input type="hidden" name="_csrf" value="{{csrfToken}}">
        <div class="floating-field">
            <input type="email" id="email" name="email" class="fancy-input" placeholder=" " required value="{{values.email}}">
            <label for="email">Email address</label>
        </div>
        <div class="floating-field">
            <input type="password" id="password" name="password" class="fancy-input" placeholder=" " required>
            <label for="password">Password</label>
        </div>

        <button type="submit" class="btn-step-next" style="margin-top:0.5rem;">
            Sign in <span class="btn-arrow">→</span>
        </button>
    </form>

    <p class="login-link" style="margin-top:1rem;">
        <a href="/forgot-password">Forgot password?</a>
    </p>
    <p class="login-link" style="margin-top:0.5rem;">
        Don't have an account? <a href="/register">Register</a>
    </p>
</div>