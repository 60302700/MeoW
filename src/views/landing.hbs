        margin: 0;
    }

    @media (max-width: 760px) {
        .scenarios { grid-template-columns: 1fr; }
        .landing-features { grid-template-columns: 1fr; }
    }

    @media (max-width: 480px) {
        .landing-wrap { padding: 2rem 1rem 1.5rem; }
        .scenario-card { padding: 1.35rem; }
    }
</style>

